  }

  function sumArmorAndCoins(callback) {
    var fields = [
      'armor_weight', 'armortype2_weight', 'armorshield_weight', 'armorhelmet_weight',
      'armor_cost', 'armortype2_cost', 'armorshield_cost', 'armorhelmet_cost',
      'pp', 'gp', 'ep', 'sp', 'cp', 'toggle_lbs',
      'normal_load_adjusted', 'heavy_load', 'very_heavy_load', 'max_load'
    ];
    getAttrs(fields, function (v) {
      var armorWeight =
        firstNumber(v.armor_weight) +
        firstNumber(v.armortype2_weight) +
        firstNumber(v.armorshield_weight) +
        firstNumber(v.armorhelmet_weight);

      var armorCost =
        num(v.armor_cost) +
        num(v.armortype2_cost) +
        num(v.armorshield_cost) +
        num(v.armorhelmet_cost);

      var coinGp = num(v.pp) + num(v.gp) + num(v.ep) + num(v.sp) + num(v.cp);
      var useLbs = String(v.toggle_lbs || '0') === '1';
      var coinDisplay = useLbs ? (coinGp / 10) : coinGp;

