function syncSpellFilterFlags() {
  getAttrs([
    'sync_caster_class1','caster_class1_selected','caster_class1_name','caster_class1_level',
    'class','secondclass','thirdclass','level','level_2','level_3'
  ], function(values) {
    const chosen = getChosenCasterClass(values);
    const className = String(chosen.className || '');
    const out = {};
    out['spell_filter_cleric'] = (className === 'cleric' || className === 'druid' || className === 'paladin' || className === 'ranger') ? '1' : '0';
    setAttrs(out, {silent:false});
  });
}

on('change:sync_caster_class1 change:caster_class1_selected change:caster_class1_name change:caster_class1_level change:class change:secondclass change:thirdclass change:level change:level_2 change:level_3', function() {
  syncSpellFilterFlags();
});

