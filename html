    for (let i=0; i<row.length; i++) arr[i+1] = row[i] || 0;
    return arr;
  }
  if (className === 'ranger') {
    const dr = SPELL_SLOT_TABLES['ranger_druid'][String(level)] || SPELL_SLOT_TABLES['ranger_druid'][level] || [];
