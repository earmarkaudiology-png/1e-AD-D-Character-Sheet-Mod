  const s = String(name || '').trim().toLowerCase();
  if (s.includes('magic') && s.includes('user')) return 'magic-user';
  if (s.includes('illusion')) return 'illusionist';
  if (s.includes('cleric')) return 'cleric';
  if (s.includes('druid')) return 'druid';
  if (s.includes('paladin')) return 'paladin';
  if (s.includes('ranger')) return 'ranger';
  return s;
}

function getChosenCasterClass(values) {
