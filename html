<script type="text/worker">
/* Custom patch v18: rollback conflicting overrides; keep only cleric/divine filter + current sync + restore existing rows */
(function(){
  const SPELL_GROUPS = ['spelllvl0','spelllvl1','spelllvl2','spelllvl3','spelllvl4','spelllvl5','spelllvl6','spelllvl7','spelllvl8','spelllvl9'];

  function detectPrimaryCaster(values) {
    const raw = [values.caster_class1_name||'', values.class||'', values.secondclass||'', values.thirdclass||''].join(' | ').toLowerCase();
    if (raw.includes('cleric') || raw.includes('druid') || raw.includes('paladin') || raw.includes('ranger')) return 'divine';
    return 'arcane';
  }

  function syncSpellFilterOnly() {
    getAttrs(['caster_class1_name','class','secondclass','thirdclass'], function(values) {
      const divine = detectPrimaryCaster(values) === 'divine' ? '1' : '0';
      setAttrs({ spell_filter_cleric: divine }, {silent:false});
    });
  }

  function syncOneCurrent(sectionName, levelIndex) {
    getSectionIDs(`repeating_${sectionName}`, function(ids) {
      const out = {};
      if (!ids || !ids.length) {
        out[`spells_lvl_${levelIndex}_current`] = '0';
        setAttrs(out, {silent:false});
        return;
      }
      const fields = ids.map(id => `repeating_${sectionName}_${id}_spell_memorized`);
      getAttrs(fields, function(values) {
        let total = 0;
        ids.forEach(function(id){ total += parseInt(values[`repeating_${sectionName}_${id}_spell_memorized`] || '0', 10) || 0; });
        out[`spells_lvl_${levelIndex}_current`] = String(total < 0 ? 0 : total);
        setAttrs(out, {silent:false});
      });
    });
  }

  function syncAllCurrents() {
    SPELL_GROUPS.forEach(function(sectionName, idx){ syncOneCurrent(sectionName, idx); });
    setTimeout(function(){ SPELL_GROUPS.forEach(function(sectionName, idx){ syncOneCurrent(sectionName, idx); }); }, 80);
  }

  function refreshExistingRows() {
    getAttrs(['caster_class1_name','class','secondclass','thirdclass'], function(classVals) {
      const divine = detectPrimaryCaster(classVals) === 'divine';
      SPELL_GROUPS.forEach(function(sectionName, idx) {
        getSectionIDs(`repeating_${sectionName}`, function(ids) {
          if (!ids || !ids.length) return;
          const fields = [];
          ids.forEach(function(id) {
            fields.push(`repeating_${sectionName}_${id}_spell_name`);
            fields.push(`repeating_${sectionName}_${id}_spell_description`);
            fields.push(`repeating_${sectionName}_${id}_spell_name_select`);
            fields.push(`repeating_${sectionName}_${id}_spell_name_select_cleric`);
          });
          getAttrs(fields, function(values) {
            ids.forEach(function(id) {
              const name = values[`repeating_${sectionName}_${id}_spell_name_select_cleric`] || values[`repeating_${sectionName}_${id}_spell_name_select`] || values[`repeating_${sectionName}_${id}_spell_name`] || '';
              const desc = values[`repeating_${sectionName}_${id}_spell_description`] || '';
              if (!name || desc) return;
              if (divine) {
                const spell = (typeof CLERIC_SPELL_MASTER !== 'undefined') ? (CLERIC_SPELL_MASTER[spellNorm(name)] || null) : null;
                if (spell) fillSpellGroupRow(sectionName, id, spell, idx, false);
              } else {
                const spell = typeof spellFind === 'function' ? spellFind(name) : null;
                if (spell) fillSpellGroupRow(sectionName, id, spell, idx, false);
              }
            });
          });
        });
      });
    });
  }

  on('sheet:opened', function(){
    syncSpellFilterOnly();
    syncAllCurrents();
    setTimeout(refreshExistingRows, 50);
    setTimeout(syncAllCurrents, 120);
  });

  on('change:sync_caster_class1 change:caster_class1_selected change:caster_class1_name change:caster_class1_level change:class change:secondclass change:thirdclass change:level change:level_2 change:level_3', function(){
    syncSpellFilterOnly();
    setTimeout(refreshExistingRows, 20);
    setTimeout(syncAllCurrents, 40);
  });

  on('change:repeating_spelllvl0:spell_memorized change:repeating_spelllvl1:spell_memorized change:repeating_spelllvl2:spell_memorized change:repeating_spelllvl3:spell_memorized change:repeating_spelllvl4:spell_memorized change:repeating_spelllvl5:spell_memorized change:repeating_spelllvl6:spell_memorized change:repeating_spelllvl7:spell_memorized change:repeating_spelllvl8:spell_memorized change:repeating_spelllvl9:spell_memorized', function(){
    syncAllCurrents();
  });

  on('remove:repeating_spelllvl0 remove:repeating_spelllvl1 remove:repeating_spelllvl2 remove:repeating_spelllvl3 remove:repeating_spelllvl4 remove:repeating_spelllvl5 remove:repeating_spelllvl6 remove:repeating_spelllvl7 remove:repeating_spelllvl8 remove:repeating_spelllvl9', function(){
    syncAllCurrents();
  });
})();


</script>





