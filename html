          if (other.veryHeavy > 0 || other.heavy > 0 || other.normal > 0) {
            if (totalGp <= other.normal) {
              enc = 0;
              label = 'Unencumbered';
            } else if (totalGp <= other.heavy) {
              enc = 1;
              label = 'Heavy';
            } else if (totalGp <= other.veryHeavy) {
              enc = 2;
              label = 'Very Heavy';
            } else {
              enc = 3;
              label = 'Max';
            }
