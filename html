arn the basic threat the trap represents.\nDetails:\n    For this spell, a “trap” is anything non-creature that would have an unexpected and undesirable effect (GM adjudication). Examples: poison needle in a lock, tripwire to a bell, a weak floor, glyph of warding.\n    Only the basic nature is revealed; specifics (poison type, pit depth, etc.) are up to the GM.\n    If the trap is magical or concealed by magic, there is a 10% chance per cleric level you can detect the involved school of magic.\n    The spell does not detect creatures and does not teach disarming/avoidance.","link":""},"know alignment":{"name":"Know Alignment","level":"2","school":"Divine divination","range":"Caster","duration":"1 turn","aoe":"1 creature, object, or place per round","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"After casting, you may focus on one target per round within 10 ft and learn its alignment.\nDetails:\n    Reveals alignment, not danger; it won’t necessarily reveal traps or poison.\n    Does not necessarily detect curses, though some horrific curses can make an item inherently evil (typically neutral evil).\n    Opaque materials interfere: penetrates metal up to 1 inch, and brick/stone up to 1 foot.\n    Most places do not have alignments, except certain sites (e.g., temples, desecrated temples, outer-planar portals, and places specifically described as good/evil/holy/unholy).\nReversible as Conceal Alignment:","notes":"After casting, you may focus on one target per round within 10 ft and learn its alignment.\nDetails:\n    Reveals alignment, not danger; it won’t necessarily reveal traps or poison.\n    Does not necessarily detect curses, though some horrific curses can make an item inherently evil (typically neutral evil).\n    Opaque materials interfere: penetrates metal up to 1 inch, and brick/stone up to 1 foot.\n    Most places do not have alignments, except certain sites (e.g., temples, desecrated temples, outer-planar portals, and places specifically described as good/evil/holy/unholy).\nReversible as Conceal Alignment:","link":""},"resist fire":{"name":"Resist Fire","level":"2","school":"Divine abjuration","range":"Touch","duration":"1 turn per cleric level","aoe":"1 creature","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"Protects the target against fire damage and heat.\nDetails:\n    Safe from non-magical fire (e.g., torches).\n    Immune to ill effects of normal heat (up to boiling).\n    Against magical or extremely hot fire, grants:\n        Provides Saving Throw: May attempt a saving throw against any magical fire effect even if none is normally allowed (typically vs spells and other magical effects).\n        Improves Saving Throw: If already allowed a save vs fire damage, may choose to add +3.\n        Reduces Damage: Fire damage is halved; if already halved (e.g., successful save), halve again. Round down.","notes":"Protects the target against fire damage and heat.\nDetails:\n    Safe from non-magical fire (e.g., torches).\n    Immune to ill effects of normal heat (up to boiling).\n    Against magical or extremely hot fire, grants:\n        Provides Saving Throw: May attempt a saving throw against any magical fire effect even if none is normally allowed (typically vs spells and other magical effects).\n        Improves Saving Throw: If already allowed a save vs fire damage, may choose to add +3.\n        Reduces Damage: Fire damage is halved; if already halved (e.g., successful save), halve again. Round down.","link":""},"silence 15 ft radius":{"name":"Silence 15 Ft Radius","level":"2","school":"Divine transmutation","range":"120 ft","duration":"2 rounds per cleric level","aoe":"15 ft radius sphere around the target","components":"V, S","ct":"5 segments","save":"See below","save_type":"","description":"Creates a zone of silence centred on a creature, object, or point in space. Within the area:\n    No sound can be produced; and\n    No sound can be heard, even from outside the zone.\nDetails:\n    Objects and points in space receive no saving throw.\n    A creature target may choose a saving throw vs spells and other magical effects:\n        Success: the target becomes the 5 ft square the creature is standing in (the creature can move out).\n        Failure: the creature remains the target; the silence moves with it.\n    Combat effects:\n        No one can cast spells with a verbal component within the area.\n        Attempts to sneak or move quietly always succeed if the creature is within the area.\n        Echolocation-dependent creatures (e.g., bats, dolphins) are blinded and suffer -4 “to hit”.","notes":"Creates a zone of silence centred on a creature, object, or point in space. Within the area:\n    No sound can be produced; and\n    No sound can be heard, even from outside the zone.\nDetails:\n    Objects and points in space receive no saving throw.\n    A creature target may choose a saving throw vs spells and other magical effects:\n        Success: the target becomes the 5 ft square the creature is standing in (the creature can move out).\n        Failure: the creature remains the target; the silence moves with it.\n    Combat effects:\n        No one can cast spells with a verbal component within the area.\n        Attempts to sneak or move quietly always succeed if the creature is within the area.\n        Echolocation-dependent creatures (e.g., bats, dolphins) are blinded and suffer -4 “to hit”.","link":""},"slow poison":{"name":"Slow Poison","level":"2","school":"Divine necromancy","range":"Touch","duration":"6 turns per cleric level","aoe":"1 creature","components":"V, S, M","ct":"Fast","save":"None","save_type":"","description":"Slows the effects of poison to keep someone alive until the poison can be neutralised (e.g., antidote or neutralise poison).\nDetails:\nPoison is often treated as “save or die,” but death is not instantaneous. This spell can slow poison and keep a victim alive within a time window determined by cleric level.\n    Target poisoned but not dead:\n    Record poison damage taken at the moment of casting; this is “slowed damage.”\n    Slowed damage is healed immediately when the spell is cast.\n    During the duration, the creature takes 1 hp poison damage every 10 rounds, but cannot be reduced below 1 hp by this poison damage until the spell ends.\n    Other (non-poison) damage applies normally.\n    Target recently dead from poison:\n    A creature counts as “recently died of poison” if it died from poison damage or from failing a save vs poison within a number of turns equal to your cleric level.\n    The creature is restored to life at the hit points it had before the poison affected it.\n    During the duration, it takes 1 hp poison damage every 10 rounds, but cannot be reduced below 1 hp by this poison damage until the spell ends.\n    Other damage applies normally.\nAdditional poison during duration:\n    Additional poison damage is not applied immediately; record it as additional slowed damage.\n    If the creature fails further saves vs poison, those poison effects are also delayed until the spell ends.\n    If the poison is not cured by the time the spell expires, all slowed poisons take full effect immediately, including the full amount of slowed damage.","notes":"Slows the effects of poison to keep someone alive until the poison can be neutralised (e.g., antidote or neutralise poison).\nDetails:\nPoison is often treated as “save or die,” but death is not instantaneous. This spell can slow poison and keep a victim alive within a time window determined by cleric level.\n    Target poisoned but not dead:\n    Record poison damage taken at the moment of casting; this is “slowed damage.”\n    Slowed damage is healed immediately when the spell is cast.\n    During the duration, the creature takes 1 hp poison damage every 10 rounds, but cannot be reduced below 1 hp by this poison damage until the spell ends.\n    Other (non-poison) damage applies normally.\n    Target recently dead from poison:\n    A creature counts as “recently died of poison” if it died from poison damage or from failing a save vs poison within a number of turns equal to your cleric level.\n    The creature is restored to life at the hit points it had before the poison affected it.\n    During the duration, it takes 1 hp poison damage every 10 rounds, but cannot be reduced below 1 hp by this poison damage until the spell ends.\n    Other damage applies normally.\nAdditional poison during duration:\n    Additional poison damage is not applied immediately; record it as additional slowed damage.\n    If the creature fails further saves vs poison, those poison effects are also delayed until the spell ends.\n    If the poison is not cured by the time the spell expires, all slowed poisons take full effect immediately, including the full amount of slowed damage.","link":""},"snake charm":{"name":"Snake Charm","level":"2","school":"Divine enchantment","range":"30 ft","duration":"2 rounds per cleric level","aoe":"One animal within range","components":"V, S","ct":"5 segments","save":"None","save_type":"","description":"Affects snakes, serpents, couatls, nagas, and other ophidian/serpentine creatures: they rear up and sway without otherwise moving, taking no actions and not attacking until the spell ends. When it ends, they forget what occurred while affected.\nDetails:\n    Total hit points of affected creatures cannot exceed your uninjured hit points. If you target more, the GM decides (or randomly determines) which are unaffected until the total affected hp is within your limit.\n    If in doubt, affected creatures include those listed above and other reptilian creatures that had no limbs when hatched. Not affected: dragons, demons, devils, wyverns.\n        Asleep/unconscious: 1d4 + 2 turns\n        Alert: 1d3 turns\n        Angry/attacking: 1d4 + 4 rounds\n    Attacking a charmed snake breaks the charm on that snake only.\nSPEAK WITH ANIMALS\nClerical transmutation, level 2\nAllows communication with a nearby animal.\nDetails:\n    You speak in Common; the animal understands magically. The animal communicates in its natural way; meaning is translated into your mind (others do not hear the translation).\n    You may attempt persuasion, deception, or bargaining for services.\n    Affects normal non-fantastic animals (wolves, badgers, bears) and giant versions without additional fantastic abilities (e.g., giant lizard yes; basilisk no).\n    Mindless animals (INT “non” or 0) are not affected. The animal must have intelligence of animal, semi-, or low.\n    Humans are not animals for this spell.\n    The spell does not compel truth, and it does not force the animal to stop fighting if you/your allies attacked it, though it usually won’t initiate combat while the spell is in effect.","notes":"Affects snakes, serpents, couatls, nagas, and other ophidian/serpentine creatures: they rear up and sway without otherwise moving, taking no actions and not attacking until the spell ends. When it ends, they forget what occurred while affected.\nDetails:\n    Total hit points of affected creatures cannot exceed your uninjured hit points. If you target more, the GM decides (or randomly determines) which are unaffected until the total affected hp is within your limit.\n    If in doubt, affected creatures include those listed above and other reptilian creatures that had no limbs when hatched. Not affected: dragons, demons, devils, wyverns.\n        Asleep/unconscious: 1d4 + 2 turns\n        Alert: 1d3 turns\n        Angry/attacking: 1d4 + 4 rounds\n    Attacking a charmed snake breaks the charm on that snake only.\nSPEAK WITH ANIMALS\nClerical transmutation, level 2\nAllows communication with a nearby animal.\nDetails:\n    You speak in Common; the animal understands magically. The animal communicates in its natural way; meaning is translated into your mind (others do not hear the translation).\n    You may attempt persuasion, deception, or bargaining for services.\n    Affects normal non-fantastic animals (wolves, badgers, bears) and giant versions without additional fantastic abilities (e.g., giant lizard yes; basilisk no).\n    Mindless animals (INT “non” or 0) are not affected. The animal must have intelligence of animal, semi-, or low.\n    Humans are not animals for this spell.\n    The spell does not compel truth, and it does not force the animal to stop fighting if you/your allies attacked it, though it usually won’t initiate combat while the spell is in effect.","link":""},"spiritual weapon":{"name":"Spiritual Weapon","level":"2","school":"Divine conjuration","range":"30 ft","duration":"1 round per cleric level","aoe":"30 ft radius around you","components":"V, S, M","ct":"5 segments","save":"None","save_type":"","description":"Creates a magical force shaped like a weapon (usually a hammer; may match your deity’s sacred weapon). It cannot move more than 30 ft from you, but within that radius it attacks where you direct it.\nDetails:\n    Each round until the spell ends, you may attack one creature within range using the spiritual weapon. Roll to hit as if using a regular weapon.\n    On a hit, it deals 1d6 magical damage (not blunt/piercing/slashing; can harm creatures immune to mundane weapons, and isn’t treated as a “weapon” for those purposes).\n    The weapon is not physical and can pass through obstacles (including walls) as long as it stays within the area.\n    If you direct it to attack a target you can’t see, you are effectively blinded with respect to that target.\n    If it attacks from behind, it gains the normal rear-attack bonus (usually +2).\n    You must concentrate to maintain the spell, or it ends (see Concentration rules).","notes":"Creates a magical force shaped like a weapon (usually a hammer; may match your deity’s sacred weapon). It cannot move more than 30 ft from you, but within that radius it attacks where you direct it.\nDetails:\n    Each round until the spell ends, you may attack one creature within range using the spiritual weapon. Roll to hit as if using a regular weapon.\n    On a hit, it deals 1d6 magical damage (not blunt/piercing/slashing; can harm creatures immune to mundane weapons, and isn’t treated as a “weapon” for those purposes).\n    The weapon is not physical and can pass through obstacles (including walls) as long as it stays within the area.\n    If you direct it to attack a target you can’t see, you are effectively blinded with respect to that target.\n    If it attacks from behind, it gains the normal rear-attack bonus (usually +2).\n    You must concentrate to maintain the spell, or it ends (see Concentration rules).","link":""},"bestow curse":{"name":"Bestow Curse","level":"3","school":"Divine conjuration","range":"Touch","duration":"Instantaneous","aoe":"1 creature","components":"V, S","ct":"6 segments","save":"Yes (negates effect)","save_type":"","description":"Places a curse on the target.\nDetails:\n    A creature can only be affected by one instance of this spell at a time.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.\n    On a successful curse, roll 1d8:\nRoll\tEffect\n1–4\tOne ability score reduced to 3\n5–6\t-4 to attack rolls and saving throws\n7–8\tClumsy: each round, 50% chance to drop each held object; if holding nothing, 50% chance it can’t act that round\nThe curse remains until removed by remove curse, dispelled, or revoked by the caster.\nOptional rule: some religions may have alternative curses (cult secrets, lost secrets, forbidden secrets), learned through donations, service, research, extraplanar consultation, or major quests (GM decides availability and effects).","notes":"Places a curse on the target.\nDetails:\n    A creature can only be affected by one instance of this spell at a time.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.\n    On a successful curse, roll 1d8:\nRoll\tEffect\n1–4\tOne ability score reduced to 3\n5–6\t-4 to attack rolls and saving throws\n7–8\tClumsy: each round, 50% chance to drop each held object; if holding nothing, 50% chance it can’t act that round\nThe curse remains until removed by remove curse, dispelled, or revoked by the caster.\nOptional rule: some religions may have alternative curses (cult secrets, lost secrets, forbidden secrets), learned through donations, service, research, extraplanar consultation, or major quests (GM decides availability and effects).","link":""},"cause blindness":{"name":"Cause Blindness","level":"3","school":"Divine transmutation","range":"Touch","duration":"Permanent","aoe":"Creature touched","components":"V, S","ct":"8 segments","save":"Yes (negates effect)","save_type":"","description":"Causes a target to become blind until removed by the caster, dispelled, or cured by cure blindness.\nDetails:\n    If you miss the to-hit roll, the spell is lost.\n    Affects only living creatures (not undead) and has no effect on creatures that do not rely on vision.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.","notes":"Causes a target to become blind until removed by the caster, dispelled, or cured by cure blindness.\nDetails:\n    If you miss the to-hit roll, the spell is lost.\n    Affects only living creatures (not undead) and has no effect on creatures that do not rely on vision.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.","link":""},"cause disease":{"name":"Cause Disease","level":"3","school":"Divine transmutation","range":"Touch","duration":"Permanent","aoe":"Creature touched","components":"V, S","ct":"10 rounds","save":"Negates effect","save_type":"","description":"Infects the target with a disease.\nDetails:\n    Requires touch (to-hit roll if resisting and not immobilised). Even on a successful touch, the target saves vs spells; success negates.\n    Affects only normally living creatures; no effect on constructs, elementals, golems, undead.\n    Takes effect 1d6 turns after casting. After it takes effect:\n        The target takes 1 hp disease damage every turn (10 rounds). Each time it takes this damage, its maximum hp is reduced by 1. This damage cannot reduce it below 1 hp, and cannot reduce maximum hp below 8 hp.\n        Every hour after it takes effect, the target suffers -1 cumulative to attack rolls and damage rolls (cannot reduce damage below 1).\n    You may end the spell at any time; if you die, the target is cured.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.","notes":"Infects the target with a disease.\nDetails:\n    Requires touch (to-hit roll if resisting and not immobilised). Even on a successful touch, the target saves vs spells; success negates.\n    Affects only normally living creatures; no effect on constructs, elementals, golems, undead.\n    Takes effect 1d6 turns after casting. After it takes effect:\n        The target takes 1 hp disease damage every turn (10 rounds). Each time it takes this damage, its maximum hp is reduced by 1. This damage cannot reduce it below 1 hp, and cannot reduce maximum hp below 8 hp.\n        Every hour after it takes effect, the target suffers -1 cumulative to attack rolls and damage rolls (cannot reduce damage below 1).\n    You may end the spell at any time; if you die, the target is cured.\n    Many good-aligned religions forbid this spell; others allow it only in dire need.","link":""},"continual darkness":{"name":"Continual Darkness","level":"3","school":"Divine transmutation","range":"120 ft","duration":"Permanent","aoe":"Globe, 60 ft radius","components":"V, S","ct":"6 segments","save":"See below","save_type":"","description":"Creates divine darkness emanating from the target (creature, object, or point in space). Light—including sunlight—does not illuminate anything within 60 ft of the target.\nDetails:\n    If cast into an area of magical light (e.g., within a light spell radius), both spells are cancelled.\n    Darkness is stationary unless cast on a moving creature/object, in which case it moves with the target.\n    You may target a creature’s eyes or other sense organs. If it fails its save (or declines to save), it is blinded for the duration. The creature applies its Dexterity save modifier (if any) to the saving throw.\n        Success: Darkness appears as a stationary point just behind the target instead of affecting it.\n    Same limitations as continual light (max 3 concurrent instances; monthly 1-in-12 chance to end).\n    Optional rule: some GMs allow infravision to see through divine darkness (cleric-slot darkness only).","notes":"Creates divine darkness emanating from the target (creature, object, or point in space). Light—including sunlight—does not illuminate anything within 60 ft of the target.\nDetails:\n    If cast into an area of magical light (e.g., within a light spell radius), both spells are cancelled.\n    Darkness is stationary unless cast on a moving creature/object, in which case it moves with the target.\n    You may target a creature’s eyes or other sense organs. If it fails its save (or declines to save), it is blinded for the duration. The creature applies its Dexterity save modifier (if any) to the saving throw.\n        Success: Darkness appears as a stationary point just behind the target instead of affecting it.\n    Same limitations as continual light (max 3 concurrent instances; monthly 1-in-12 chance to end).\n    Optional rule: some GMs allow infravision to see through divine darkness (cleric-slot darkness only).","link":""},"create food and water":{"name":"Create Food and Water","level":"3","school":"Divine conjuration","range":"10 ft","duration":"Instantaneous","aoe":"See below","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"Conjures basic food and water from thin air. You choose the form of the food, but it is plain fare.\nDetails:\n    Food is safe when conjured but spoils normally thereafter.\n    For each cleric level, you conjure up to one day’s rations for one human-sized creature.\n    The target point can’t be inside a creature.","notes":"Conjures basic food and water from thin air. You choose the form of the food, but it is plain fare.\nDetails:\n    Food is safe when conjured but spoils normally thereafter.\n    For each cleric level, you conjure up to one day’s rations for one human-sized creature.\n    The target point can’t be inside a creature.","link":""},"cure blindness":{"name":"Cure Blindness","level":"3","school":"Divine transmutation","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"8 segments","save":"None","save_type":"","description":"Cures blindness in one living creature, subject to limitations. Typically only effective for magically induced blindness (e.g., curses, cause blindness).\nDetails:\n    Restores sight only to the extent the creature’s eyes allow; it does not repair destroyed/damaged eyes. A creature whose eyes were put out gains no benefit.\n    Does not cure blindness that exists in the mind (e.g., believing it is blind due to an illusion); does not remove hallucinations from false seeing.\n    Does not remove environmental obstruction (fog/darkness), though it does remove light or continual light cast on the eyes.\nReversible as Cause Blindness:","notes":"Cures blindness in one living creature, subject to limitations. Typically only effective for magically induced blindness (e.g., curses, cause blindness).\nDetails:\n    Restores sight only to the extent the creature’s eyes allow; it does not repair destroyed/damaged eyes. A creature whose eyes were put out gains no benefit.\n    Does not cure blindness that exists in the mind (e.g., believing it is blind due to an illusion); does not remove hallucinations from false seeing.\n    Does not remove environmental obstruction (fog/darkness), though it does remove light or continual light cast on the eyes.\nReversible as Cause Blindness:","link":""},"cure disease":{"name":"Cure Disease","level":"3","school":"Divine transmutation","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"10 rounds","save":"None","save_type":"","description":"Cures all diseases affecting the target (see details). Full recovery may take up to a week.\nDetails:\n    Stops the “will die in X days” progression immediately; the target is no longer at risk of dying from disease, even if not yet back to full strength.\n    Cures physical pathologies and removes physical parasites. Does not cure genetic conditions/birth defects; affects mental health only insofar as curing underlying pathology/parasites helps.\n    Affects only normally living creatures; no effect on constructs, elementals, golems, undead.\n    Cures lycanthropy only if cast before the first transformation. After first change, lycanthropy becomes a mixed disease/curse/magical alteration.\n    The target may choose a saving throw vs spells and other effects; on a success, one or more diseases of its choice are not cured.\n    Has certain special uses that cure non-disease effects in specific OSRIC creature/object entries.\nReversible as Cause Disease:","notes":"Cures all diseases affecting the target (see details). Full recovery may take up to a week.\nDetails:\n    Stops the “will die in X days” progression immediately; the target is no longer at risk of dying from disease, even if not yet back to full strength.\n    Cures physical pathologies and removes physical parasites. Does not cure genetic conditions/birth defects; affects mental health only insofar as curing underlying pathology/parasites helps.\n    Affects only normally living creatures; no effect on constructs, elementals, golems, undead.\n    Cures lycanthropy only if cast before the first transformation. After first change, lycanthropy becomes a mixed disease/curse/magical alteration.\n    The target may choose a saving throw vs spells and other effects; on a success, one or more diseases of its choice are not cured.\n    Has certain special uses that cure non-disease effects in specific OSRIC creature/object entries.\nReversible as Cause Disease:","link":""},"glyph of warding":{"name":"Glyph of Warding","level":"3","school":"Divine evocation","range":"Touch","duration":"Until discharged","aoe":"Up to 25 sq. ft per cleric level","components":"V, S, M","ct":"1 segment per sq. ft protected","save":"When activated (save for half)","save_type":"","description":"You inscribe an invisible glyph on a solid surface. It remains invisible unless detect magic is used. A “forbidden creature” (as defined at casting) discharges the glyph when it performs a defined triggering action.\nDetails:\n    You must define:\n        A forbidden creature (e.g., “any living being,” “anyone but myself,” “a dwarf,” “Richard the Necrophage,” etc.).\n        A triggering action (typically opening a warded door or passing through a warded area).\n        The exact area to be warded.\n    When triggered, each creature in the area may save vs spells/spell-like effects:\n        Success: half damage and may disregard other glyph effects (if any).\n    You must know the specific glyph you’re using. Fire/lightning/ice/acid glyphs are secrets of clerical orders; blindness/paralysis are lost secrets; drain/petrify/banish are long-lost and widely forbidden, requiring major effort/quests to learn.\n    If warding more than 50 sq. ft, gems worth 2,000 gp must be destroyed as a material component.\n    You can only use glyph types permitted by your cleric level:\nMinimum Cleric Level\tGlyph\tNoise\tEffect\n3\tFire\tNoisy\t2 hp fire damage per cleric level\n5\tLightning\tLoud\t2 hp lightning damage per cleric level\n7\tIce\tQuiet\t2 hp cold damage per cleric level\n9\tAcid\tQuiet\t2 hp corrosion damage per cleric level\n11\tBlindness\tSilent\tSave or blinded for 3d6 rounds\n13\tParalysis\tSilent\tSave or paralysed for 2d6 rounds\n15\tDrain\tSilent\tSave or lose 1 life energy level\n17\tPetrify\tSilent\tSave or turned to stone\n20\tBanish\tSilent\tSave or sent to deity-associated plane","notes":"You inscribe an invisible glyph on a solid surface. It remains invisible unless detect magic is used. A “forbidden creature” (as defined at casting) discharges the glyph when it performs a defined triggering action.\nDetails:\n    You must define:\n        A forbidden creature (e.g., “any living being,” “anyone but myself,” “a dwarf,” “Richard the Necrophage,” etc.).\n        A triggering action (typically opening a warded door or passing through a warded area).\n        The exact area to be warded.\n    When triggered, each creature in the area may save vs spells/spell-like effects:\n        Success: half damage and may disregard other glyph effects (if any).\n    You must know the specific glyph you’re using. Fire/lightning/ice/acid glyphs are secrets of clerical orders; blindness/paralysis are lost secrets; drain/petrify/banish are long-lost and widely forbidden, requiring major effort/quests to learn.\n    If warding more than 50 sq. ft, gems worth 2,000 gp must be destroyed as a material component.\n    You can only use glyph types permitted by your cleric level:\nMinimum Cleric Level\tGlyph\tNoise\tEffect\n3\tFire\tNoisy\t2 hp fire damage per cleric level\n5\tLightning\tLoud\t2 hp lightning damage per cleric level\n7\tIce\tQuiet\t2 hp cold damage per cleric level\n9\tAcid\tQuiet\t2 hp corrosion damage per cleric level\n11\tBlindness\tSilent\tSave or blinded for 3d6 rounds\n13\tParalysis\tSilent\tSave or paralysed for 2d6 rounds\n15\tDrain\tSilent\tSave or lose 1 life energy level\n17\tPetrify\tSilent\tSave or turned to stone\n20\tBanish\tSilent\tSave or sent to deity-associated plane","link":""},"prayer":{"name":"Prayer","level":"3","school":"Divine abjuration","range":"Nil","duration":"1 round per cleric level","aoe":"60 ft radius","components":"V, S, M","ct":"6 segments","save":"None","save_type":"","description":"The target location is where you stand when casting completes. Until the spell ends, within the area:\n    You and your allies may choose to gain +1 to attack rolls, damage rolls, and saving throws.\n    Enemies suffer -1 to attack rolls, damage rolls, and saving throws.\nDetails:\n    Cumulative with chant despite similarity.","notes":"The target location is where you stand when casting completes. Until the spell ends, within the area:\n    You and your allies may choose to gain +1 to attack rolls, damage rolls, and saving throws.\n    Enemies suffer -1 to attack rolls, damage rolls, and saving throws.\nDetails:\n    Cumulative with chant despite similarity.","link":""},"speak with dead":{"name":"Speak with Dead","level":"3","school":"Divine necromancy","range":"10 ft","duration":"Varies (see table)","aoe":"One corpse","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"Compels a corpse to answer questions aloud (others can hear). Duration, question limit, and maximum corpse age depend on your cleric level.\nLimitations by cleric level:\nCleric Level\tDuration\tMax Questions\tMax Time Since Death\n5–6\t1 round\t2\t1 week\n7–8\t3 rounds\t3\t1 month\n9–12\t1 turn\t4\t1 year\n13–15\t2 turns\t5\t1 decade\n16–19\t3 turns\t6\t1 century\n20\t1 hour\t7\t1 aeon\nDetails:\n    The corpse can only tell what it knew in life.\n    It only speaks languages it knew in life. If it doesn’t understand a question, it can say “I don’t understand,” and this still consumes one question.\n    The spell does not make it friendly. If it was hostile (especially if you killed it), it answers briefly and with minimal information.\n    Multi-part questions get only one part answered (corpse chooses which).\n    Ambiguous questions may be interpreted in any reasonable way (GM adjudication).\n    If the target is undead, it does not have to stop fighting while answering.","notes":"Compels a corpse to answer questions aloud (others can hear). Duration, question limit, and maximum corpse age depend on your cleric level.\nLimitations by cleric level:\nCleric Level\tDuration\tMax Questions\tMax Time Since Death\n5–6\t1 round\t2\t1 week\n7–8\t3 rounds\t3\t1 month\n9–12\t1 turn\t4\t1 year\n13–15\t2 turns\t5\t1 decade\n16–19\t3 turns\t6\t1 century\n20\t1 hour\t7\t1 aeon\nDetails:\n    The corpse can only tell what it knew in life.\n    It only speaks languages it knew in life. If it doesn’t understand a question, it can say “I don’t understand,” and this still consumes one question.\n    The spell does not make it friendly. If it was hostile (especially if you killed it), it answers briefly and with minimal information.\n    Multi-part questions get only one part answered (corpse chooses which).\n    Ambiguous questions may be interpreted in any reasonable way (GM adjudication).\n    If the target is undead, it does not have to stop fighting while answering.","link":""},"blither":{"name":"Blither","level":"4","school":"Divine enchantment","range":"Touch","duration":"1 turn","aoe":"One creature","components":"V, S, M","ct":"7 segments","save":"Yes (negates effect)","save_type":"","description":"Noise: Casting quiet; effect quiet\nRenders a creature’s spoken words meaningless for the duration; it cannot communicate via speech.\nDetails:\n    Target may add its Wisdom saving throw modifier to the saving throw.\n    On failure, it can still gesture, write, and otherwise communicate.\n    The affected creature cannot cast spells with verbal components until the spell ends.","notes":"Noise: Casting quiet; effect quiet\nRenders a creature’s spoken words meaningless for the duration; it cannot communicate via speech.\nDetails:\n    Target may add its Wisdom saving throw modifier to the saving throw.\n    On failure, it can still gesture, write, and otherwise communicate.\n    The affected creature cannot cast spells with verbal components until the spell ends.","link":""},"cause serious wounds":{"name":"Cause Serious Wounds","level":"4","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"7 segments","save":"None","save_type":"","description":"The touched target takes 2d8+1 hit points of magical damage, even if it can only be hit by magical weapons. Touching the target requires a successful to-hit roll; no saving throw is allowed.\nDetails:\nIf you miss the to-hit roll, no damage is inflicted and the spell is lost. This spell affects only naturally living creatures and does not affect golems, constructs, elementals, or undead.","notes":"The touched target takes 2d8+1 hit points of magical damage, even if it can only be hit by magical weapons. Touching the target requires a successful to-hit roll; no saving throw is allowed.\nDetails:\nIf you miss the to-hit roll, no damage is inflicted and the spell is lost. This spell affects only naturally living creatures and does not affect golems, constructs, elementals, or undead.","link":""},"cure serious wounds":{"name":"Cure Serious Wounds","level":"4","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"7 segments","save":"None","save_type":"","description":"The target regains 2d8+1 hit points, up to its normal maximum. Any healing beyond the normal maximum is wasted.\nDetails:\nThis spell cannot cure disease, reattach limbs, raise the dead, or heal afflictions not measured in hit points; such effects require stronger magic. It generally affects only normally living creatures and has no effect on golems, constructs, elementals, or undead.\nReversible as Cause Serious Wounds:","notes":"The target regains 2d8+1 hit points, up to its normal maximum. Any healing beyond the normal maximum is wasted.\nDetails:\nThis spell cannot cure disease, reattach limbs, raise the dead, or heal afflictions not measured in hit points; such effects require stronger magic. It generally affects only normally living creatures and has no effect on golems, constructs, elementals, or undead.\nReversible as Cause Serious Wounds:","link":""},"detect lie":{"name":"Detect Lie","level":"4","school":"Divine divination","range":"30 ft","duration":"1 round per cleric level","aoe":"One creature you designate","components":"V, S, M","ct":"7 segments","save":"None","save_type":"","description":"Cast upon a specific creature. For the duration, when that creature speaks, you know whether it is saying something it does not believe to be true.\nDetails:\nYour awareness of lies is not detectable by others. The spell affects only speech, not telepathy or writing. You can only detect lies you can hear. Lies spoken in languages you do not know are still detected as lies, but you will not know what was actually said.\nReversible as Glibness:","notes":"Cast upon a specific creature. For the duration, when that creature speaks, you know whether it is saying something it does not believe to be true.\nDetails:\nYour awareness of lies is not detectable by others. The spell affects only speech, not telepathy or writing. You can only detect lies you can hear. Lies spoken in languages you do not know are still detected as lies, but you will not know what was actually said.\nReversible as Glibness:","link":""},"divination":{"name":"Divination","level":"4","school":"Divine divination","range":"Caster","duration":"1 round","aoe":"Caster","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"Gives information about a place via divination (bones, yarrow stalks, tea leaves, entrails, etc.). You may misinterpret the reading.\nDetails:\n    The divination must be about a place. You do not need to be there; you need only its approximate location. It cannot be about an object unless it is so large it counts as a place (e.g., a building).\n    The GM secretly rolls 1d6:\n        1–4: You interpret correctly.\n        5–6: You interpret incorrectly.\n    If you sacrifice a magical item as part of the divination, it is destroyed and the GM’s d6 roll is modified by -1. Artifacts, relics, and equivalent items cannot be sacrificed or destroyed by this spell.\n    The GM provides your character’s interpretation of:\n        Whether the place is sacred to a god/demigod/power, and which;\n        Whether creatures inhabit it;\n        Whether those creatures are weak/equivalent/strong compared to you;\n        Whether treasure is present; and\n        Whether the treasure is poor/medium/rich.\n    If you misinterpret, the GM answers randomly with a mixture of correct and incorrect information.\n    Some legendary places are specially warded; divination always misinterprets those places.","notes":"Gives information about a place via divination (bones, yarrow stalks, tea leaves, entrails, etc.). You may misinterpret the reading.\nDetails:\n    The divination must be about a place. You do not need to be there; you need only its approximate location. It cannot be about an object unless it is so large it counts as a place (e.g., a building).\n    The GM secretly rolls 1d6:\n        1–4: You interpret correctly.\n        5–6: You interpret incorrectly.\n    If you sacrifice a magical item as part of the divination, it is destroyed and the GM’s d6 roll is modified by -1. Artifacts, relics, and equivalent items cannot be sacrificed or destroyed by this spell.\n    The GM provides your character’s interpretation of:\n        Whether the place is sacred to a god/demigod/power, and which;\n        Whether creatures inhabit it;\n        Whether those creatures are weak/equivalent/strong compared to you;\n        Whether treasure is present; and\n        Whether the treasure is poor/medium/rich.\n    If you misinterpret, the GM answers randomly with a mixture of correct and incorrect information.\n    Some legendary places are specially warded; divination always misinterprets those places.","link":""},"exorcise":{"name":"Exorcise","level":"4","school":"Divine abjuration","range":"10 ft","duration":"Instantaneous (or continuing; see below)","aoe":"One creature, object, or place","components":"V, S, M","ct":"10 rounds, continuing","save":"Depends on use (see below)","save_type":"","description":"A multi-purpose ritual to cast out a supernatural creature or influence (fiend, ghost, etc.) possessing a creature/object. It can also remove a curse or end a charm/enchantment. The casting and effect are loud.\nDetails:\nUsing the spell to remove curses / end charm or enchantment:\n    Automatically succeeds when you finish the first turn of casting.\n    Unwilling targets do not receive a saving throw for this use.\nUsing the spell to cast out supernatural creatures and influences:\n    On a good-aligned outer plane: automatically succeeds after the first turn.\n    On an evil-aligned outer plane: automatically fails.\n    Otherwise, each turn you continue casting, the creature/influence rolls a special saving throw on d20; failure means it is exorcised.\nSaving throws versus exorcism (base target numbers):\nCreature/Influence Strength\tBase Saving Throw\nWeak influence, dretch, spiked devil\t10\nModerate influence, class A demon, shub demon, bearded devil, erinyes, scaly devil\t8\nClass B demon, uduk demon, ekivu demon, ghost, succubus, barbed devil\t7\nClass C demon, babau demon, bone devil\t6\nStrong influence, class D demon, horned devil\t5\nClass E demon, ice devil, night hag\t4\nClass F demon, pit fiend, shaitan devil\t3\nModifiers:\n    Apply -1 to the creature’s saving throw for each cleric level you have above 8.\n    If you hold a relevant artifact/relic, the GM may assign an additional -1 to -4 modifier (based on strength/aptitude/inclination).\n    Magic resistance does not apply.\n    On a natural 20 on its saving throw, you suffer an ill effect (e.g., curse or loss of 1 point from a random ability score).\n    Cannot exorcise artifacts, relics, deities, or equivalent powers.\nEffect of exorcism:\nThe cast-out creature returns to its own body (or nearest body if it has several). If bodiless, it appears on the Prime Material Plane adjacent to the formerly possessed target (GM chooses or randomises if multiple possible).","notes":"A multi-purpose ritual to cast out a supernatural creature or influence (fiend, ghost, etc.) possessing a creature/object. It can also remove a curse or end a charm/enchantment. The casting and effect are loud.\nDetails:\nUsing the spell to remove curses / end charm or enchantment:\n    Automatically succeeds when you finish the first turn of casting.\n    Unwilling targets do not receive a saving throw for this use.\nUsing the spell to cast out supernatural creatures and influences:\n    On a good-aligned outer plane: automatically succeeds after the first turn.\n    On an evil-aligned outer plane: automatically fails.\n    Otherwise, each turn you continue casting, the creature/influence rolls a special saving throw on d20; failure means it is exorcised.\nSaving throws versus exorcism (base target numbers):\nCreature/Influence Strength\tBase Saving Throw\nWeak influence, dretch, spiked devil\t10\nModerate influence, class A demon, shub demon, bearded devil, erinyes, scaly devil\t8\nClass B demon, uduk demon, ekivu demon, ghost, succubus, barbed devil\t7\nClass C demon, babau demon, bone devil\t6\nStrong influence, class D demon, horned devil\t5\nClass E demon, ice devil, night hag\t4\nClass F demon, pit fiend, shaitan devil\t3\nModifiers:\n    Apply -1 to the creature’s saving throw for each cleric level you have above 8.\n    If you hold a relevant artifact/relic, the GM may assign an additional -1 to -4 modifier (based on strength/aptitude/inclination).\n    Magic resistance does not apply.\n    On a natural 20 on its saving throw, you suffer an ill effect (e.g., curse or loss of 1 point from a random ability score).\n    Cannot exorcise artifacts, relics, deities, or equivalent powers.\nEffect of exorcism:\nThe cast-out creature returns to its own body (or nearest body if it has several). If bodiless, it appears on the Prime Material Plane adjacent to the formerly possessed target (GM chooses or randomises if multiple possible).","link":""},"glibness":{"name":"Glibness","level":"4","school":"Divine transmutation","range":"30 ft","duration":"1 round per cleric level","aoe":"One creature","components":"V, S, M","ct":"7 segments","save":"None","save_type":"","description":"Counters detect lie on the target; if detect lie is not in effect, the target’s lies become more convincing.\nDetails:\n    A creature can only be affected by one instance of this spell at a time.\n    As with most targeted spells, you can cast it on yourself or another creature.\n    Lies are only believed if the listener can hear and understand them.\n    The GM determines plausibility; each listener then rolls a special saving throw on a d20 (optionally adding their Wisdom save modifier).\nSaving throw targets for Glibness:\nPlausibility\tSaving Throw Target\nLikely\t20\nPlausible\t18\nPossible\t15\nSurprising\t11\nUnlikely\t7\nObviously false\t2\nIf the listener passes, they do not believe the lie.","notes":"Counters detect lie on the target; if detect lie is not in effect, the target’s lies become more convincing.\nDetails:\n    A creature can only be affected by one instance of this spell at a time.\n    As with most targeted spells, you can cast it on yourself or another creature.\n    Lies are only believed if the listener can hear and understand them.\n    The GM determines plausibility; each listener then rolls a special saving throw on a d20 (optionally adding their Wisdom save modifier).\nSaving throw targets for Glibness:\nPlausibility\tSaving Throw Target\nLikely\t20\nPlausible\t18\nPossible\t15\nSurprising\t11\nUnlikely\t7\nObviously false\t2\nIf the listener passes, they do not believe the lie.","link":""},"neutralise poison":{"name":"Neutralise Poison","level":"4","school":"Divine transmutation","range":"Touch","duration":"Instantaneous","aoe":"1 ft cube per 2 cleric levels, or one creature","components":"V, S","ct":"7 segments","save":"Depends on use (see below)","save_type":"","description":"Purges venom/toxin/contaminant, rendering it harmless. Can potentially revive someone who has recently “died” from poison.\nDetails:\n    Does not affect disease-based contamination.\n    Gods/demigods/artifacts/relics/equivalent are not affected (GM may allow some derivative effects to be affected).\n    If targeting a toxic place, all toxins/contaminants are purged from the area.\nUsing the spell to de-venom an opponent:\n    If the target is a creature, it may choose a saving throw vs spells and other magical effects.\n        Success: not affected.\n        Failure: if it has a venomous attack, the venom component is nullified until dawn the next day.\nUsing the spell to revive someone “dead by poison”:\n    If the target is poisoned, all toxins are purged, but poison damage already taken remains.\n    Also works on creatures that have recently died of poison: death from poison damage or failed save vs poison within a number of turns equal to your cleric level.\nReversible as Poison:","notes":"Purges venom/toxin/contaminant, rendering it harmless. Can potentially revive someone who has recently “died” from poison.\nDetails:\n    Does not affect disease-based contamination.\n    Gods/demigods/artifacts/relics/equivalent are not affected (GM may allow some derivative effects to be affected).\n    If targeting a toxic place, all toxins/contaminants are purged from the area.\nUsing the spell to de-venom an opponent:\n    If the target is a creature, it may choose a saving throw vs spells and other magical effects.\n        Success: not affected.\n        Failure: if it has a venomous attack, the venom component is nullified until dawn the next day.\nUsing the spell to revive someone “dead by poison”:\n    If the target is poisoned, all toxins are purged, but poison damage already taken remains.\n    Also works on creatures that have recently died of poison: death from poison damage or failed save vs poison within a number of turns equal to your cleric level.\nReversible as Poison:","link":""},"poison":{"name":"Poison","level":"4","school":"Divine transmutation","range":"Touch","duration":"Instantaneous","aoe":"1 ft cube per 2 cleric levels, including no more than one creature","components":"V, S","ct":"7 segments","save":"Depends on use (see below)","save_type":"","description":"Your touch becomes deadly poison, or you can make an edible/potable substance poisonous. In either case, you must touch the target.\nDetails:\n    If targeting a creature, it may attempt a saving throw vs poison; success negates.\n    Creatures immune to poison are unaffected.\n    Gods/demigods/artifacts/relics/equivalent are unaffected.\n    If a creature fails its save: it dies.\n    If an edible/potable is poisoned: the first creature to consume must save vs poison or die (unless immune). After that save is resolved, remaining poison is nullified.","notes":"Your touch becomes deadly poison, or you can make an edible/potable substance poisonous. In either case, you must touch the target.\nDetails:\n    If targeting a creature, it may attempt a saving throw vs poison; success negates.\n    Creatures immune to poison are unaffected.\n    Gods/demigods/artifacts/relics/equivalent are unaffected.\n    If a creature fails its save: it dies.\n    If an edible/potable is poisoned: the first creature to consume must save vs poison or die (unless immune). After that save is resolved, remaining poison is nullified.","link":""},"protection from evil 10 ft radius":{"name":"Protection from Evil 10 Ft Radius","level":"4","school":"Divine abjuration","range":"Touch","duration":"10 rounds per cleric level","aoe":"10 ft radius around the creature touched","components":"V, S, M","ct":"7 segments","save":"None","save_type":"","description":"Creates a 10 ft radius invisible barrier against evil and summoned creatures around the protected creature.\nDetails:\n    Cast on yourself or another willing creature; not on hostile creatures, objects, or places.\n    A creature can only be affected by one instance at a time. If already warded by the 1st-level protection from evil, this spell has no effect on it.\n    Effects within the warded area:\n        Evil creatures: -2 to attack rolls into the warded area; anyone inside gains +2 on saving throws caused by evil creatures or their effects.\n        Evil effects (rare): effects explicitly described as evil/fiendish/demonic/devilish allow +2 to saving throws.\n        Summoned/conjured creatures: cannot attack into the warded area by touch (claws, teeth, etc.), regardless of alignment. They only suffer the -2 penalty in (1) if they are evil. (A non-evil summoned creature could still attack with a long weapon if it can reach.)\n    Ghouls: additionally “kept at bay” (cannot reduce distance to the warded area), but if the warded area moves toward them, they need not retreat. Some GMs extend “kept at bay” beyond ghouls.\nReversible as Protection from Good 10 ft Radius:","notes":"Creates a 10 ft radius invisible barrier against evil and summoned creatures around the protected creature.\nDetails:\n    Cast on yourself or another willing creature; not on hostile creatures, objects, or places.\n    A creature can only be affected by one instance at a time. If already warded by the 1st-level protection from evil, this spell has no effect on it.\n    Effects within the warded area:\n        Evil creatures: -2 to attack rolls into the warded area; anyone inside gains +2 on saving throws caused by evil creatures or their effects.\n        Evil effects (rare): effects explicitly described as evil/fiendish/demonic/devilish allow +2 to saving throws.\n        Summoned/conjured creatures: cannot attack into the warded area by touch (claws, teeth, etc.), regardless of alignment. They only suffer the -2 penalty in (1) if they are evil. (A non-evil summoned creature could still attack with a long weapon if it can reach.)\n    Ghouls: additionally “kept at bay” (cannot reduce distance to the warded area), but if the warded area moves toward them, they need not retreat. Some GMs extend “kept at bay” beyond ghouls.\nReversible as Protection from Good 10 ft Radius:","link":""},"protection from good 10 ft radius":{"name":"Protection from Good 10 Ft Radius","level":"4","school":"Divine abjuration","range":"Touch","duration":"10 rounds per cleric level","aoe":"10 ft radius around the creature touched","components":"V, S, M","ct":"7 segments","save":"None","save_type":"","description":"Creates a 10 ft radius barrier against good-aligned and summoned creatures around the protected creature.\nDetails:\n    Same targeting limits and stacking limits as the evil version (and does not affect a creature already warded by 1st-level protection from good).\n    Effects:\n        Good creatures: -2 to attack rolls into the warded area; anyone inside gains +2 on saving throws caused by good creatures or their effects.\n        Holy effects (rare): effects explicitly described as “holy” allow +2 to saving throws.\n        Summoned/conjured creatures: cannot attack into the warded area by touch, regardless of alignment; only take the -2 penalty if actually good-aligned. (A non-good summoned creature could still attack with a long weapon if it can reach.)","notes":"Creates a 10 ft radius barrier against good-aligned and summoned creatures around the protected creature.\nDetails:\n    Same targeting limits and stacking limits as the evil version (and does not affect a creature already warded by 1st-level protection from good).\n    Effects:\n        Good creatures: -2 to attack rolls into the warded area; anyone inside gains +2 on saving throws caused by good creatures or their effects.\n        Holy effects (rare): effects explicitly described as “holy” allow +2 to saving throws.\n        Summoned/conjured creatures: cannot attack into the warded area by touch, regardless of alignment; only take the -2 penalty if actually good-aligned. (A non-good summoned creature could still attack with a long weapon if it can reach.)","link":""},"raise water":{"name":"Raise Water","level":"4","school":"Divine transmutation","range":"120 ft","duration":"1 turn per cleric level","aoe":"Up to 10 ft square of surface area per cleric level","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"Water in the affected area rises by 5 ft. If you can affect the same area multiple times, you may raise it an additional 5 ft per iteration.\nDetails:\nAdditional water comes from the Elemental Plane of Water for the duration and returns when the spell ends (about room temperature). Target liquid must be non-magical and roughly water-like viscosity. If the target is a water creature (water weird/elemental), it is affected as if by an enlarge spell.","notes":"Water in the affected area rises by 5 ft. If you can affect the same area multiple times, you may raise it an additional 5 ft per iteration.\nDetails:\nAdditional water comes from the Elemental Plane of Water for the duration and returns when the spell ends (about room temperature). Target liquid must be non-magical and roughly water-like viscosity. If the target is a water creature (water weird/elemental), it is affected as if by an enlarge spell.","link":""},"snakes to sticks":{"name":"Snakes to Sticks","level":"4","school":"Divine transmutation","range":"30 ft","duration":"2 rounds per cleric level","aoe":"10 ft cube","components":"V, S, M","ct":"7 segments","save":"Yes (negates effect)","save_type":"","description":"Transforms ophidian creatures into sticks temporarily. Affects snakes, serpents, couatls, nagas, and similar; maximum of one creature per cleric level.\nDetails:\n    Targets may save vs spells and other magical effects; success negates.\n    If unclear, affected creatures include those listed above and other reptilian creatures that lacked limbs when hatched. Dragons, demons, devils, and wyverns are not “snakes” for this spell.\n    Some ophidian creatures are too large to fit in the area and cannot be affected.\n    While wood, snakes can be broken/burned/destroyed; if destroyed, they are dead when the spell ends.","notes":"Transforms ophidian creatures into sticks temporarily. Affects snakes, serpents, couatls, nagas, and similar; maximum of one creature per cleric level.\nDetails:\n    Targets may save vs spells and other magical effects; success negates.\n    If unclear, affected creatures include those listed above and other reptilian creatures that lacked limbs when hatched. Dragons, demons, devils, and wyverns are not “snakes” for this spell.\n    Some ophidian creatures are too large to fit in the area and cannot be affected.\n    While wood, snakes can be broken/burned/destroyed; if destroyed, they are dead when the spell ends.","link":""},"speak with plants":{"name":"Speak with Plants","level":"4","school":"Divine transmutation","range":"30 ft","duration":"1 round per cleric level","aoe":"One plant within range","components":"V, S","ct":"10 rounds","save":"None","save_type":"","description":"Lets you communicate with a nearby plant and understand its “speech.”\nDetails:\n    Only you hear the magical translation.\n    You speak in Common; the plant understands. It replies in its natural mode; the spell translates into your mind.\n    Some plants may be mobile/dangerous; you can bargain/persuade/deceive as appropriate.\n    GM decides what counts as a “plant.”\n    The plant usually won’t start combat until the spell ends, but if you/your allies attacked it in the last turn, it is not required to stop fighting.\n    Does not compel truth.","notes":"Lets you communicate with a nearby plant and understand its “speech.”\nDetails:\n    Only you hear the magical translation.\n    You speak in Common; the plant understands. It replies in its natural mode; the spell translates into your mind.\n    Some plants may be mobile/dangerous; you can bargain/persuade/deceive as appropriate.\n    GM decides what counts as a “plant.”\n    The plant usually won’t start combat until the spell ends, but if you/your allies attacked it in the last turn, it is not required to stop fighting.\n    Does not compel truth.","link":""},"sticks to snakes":{"name":"Sticks to Snakes","level":"4","school":"Divine transmutation","range":"30 ft","duration":"2 rounds per cleric level","aoe":"10 ft cube; max 1 stick per cleric level","components":"V, S, M","ct":"7 segments","save":"None","save_type":"","description":"Transforms dead wood into serpents. The serpents do not understand speech, but obey mental commands to attack a target.\nFor each snake created, roll 1d20: if the result is ≤ your cleric level, the snake is venomous; otherwise it is a constrictor.\nDetails:\n    Affects roughly cylindrical dead-wood objects, up to a maximum number equal to your cleric level. Targets cannot be magical.\n    If you aren’t in a forest, bring your own sticks.\nVenomous Snake: AC 6, MV 90 ft, HD 2, #AT 1, Dmg 1 piercing, SA poison (save vs poison or die; apply CON modifier to save), Size S, AL N.\nConstrictor Snake: AC 6, MV 90 ft, HD 2, #AT 1, Dmg 1 blunt, SA constrict (on hit: constricts until it releases or is killed; one target at a time; may deal 1d4 blunt damage on its initiative instead of attacking), Size S, AL N.\nNo XP is awarded for killing/defeating snakes created by this spell.\nReversible as Snakes to Sticks:","notes":"Transforms dead wood into serpents. The serpents do not understand speech, but obey mental commands to attack a target.\nFor each snake created, roll 1d20: if the result is ≤ your cleric level, the snake is venomous; otherwise it is a constrictor.\nDetails:\n    Affects roughly cylindrical dead-wood objects, up to a maximum number equal to your cleric level. Targets cannot be magical.\n    If you aren’t in a forest, bring your own sticks.\nVenomous Snake: AC 6, MV 90 ft, HD 2, #AT 1, Dmg 1 piercing, SA poison (save vs poison or die; apply CON modifier to save), Size S, AL N.\nConstrictor Snake: AC 6, MV 90 ft, HD 2, #AT 1, Dmg 1 blunt, SA constrict (on hit: constricts until it releases or is killed; one target at a time; may deal 1d4 blunt damage on its initiative instead of attacking), Size S, AL N.\nNo XP is awarded for killing/defeating snakes created by this spell.\nReversible as Snakes to Sticks:","link":""},"atonement":{"name":"Atonement","level":"5","school":"Divine abjuration","range":"Touch","duration":"Instantaneous","aoe":"One creature","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"You request forgiveness for the target’s past sins and transgressions. Any punishments imposed by gods or spirits are removed (see details). The spell can only be cast on a willing creature.\nDetails:\nThe spell ends without effect if:\n    Your alignment is chaotic and the target’s is lawful;\n    Your alignment is lawful and the target’s is chaotic;\n    Your alignment is good and the target’s is evil; or\n    Your alignment is evil and the target’s is good.\nIf the target’s transgressions were involuntary, unwilling, or unwitting, and the target is truly sorry, punishments are lifted unconditionally.\nIf the transgressions were involuntary, unwilling, or unwitting, and the target is not truly sorry, the gods/spirits assign a penance or quest; punishments are lifted when it is completed.\nIf the transgressions occurred while the target’s mind/brain was disturbed (charm, domination, mind control, possession), and the disturbance is ongoing, punishments are lifted unconditionally regardless of remorse, and the disturbance ends.\nIf the transgressions were voluntary but the target honestly believed they were for the greater good, the GM determines whether the repentance is accepted. If accepted, a penance/quest is assigned; punishments are lifted when it is completed.","notes":"You request forgiveness for the target’s past sins and transgressions. Any punishments imposed by gods or spirits are removed (see details). The spell can only be cast on a willing creature.\nDetails:\nThe spell ends without effect if:\n    Your alignment is chaotic and the target’s is lawful;\n    Your alignment is lawful and the target’s is chaotic;\n    Your alignment is good and the target’s is evil; or\n    Your alignment is evil and the target’s is good.\nIf the target’s transgressions were involuntary, unwilling, or unwitting, and the target is truly sorry, punishments are lifted unconditionally.\nIf the transgressions were involuntary, unwilling, or unwitting, and the target is not truly sorry, the gods/spirits assign a penance or quest; punishments are lifted when it is completed.\nIf the transgressions occurred while the target’s mind/brain was disturbed (charm, domination, mind control, possession), and the disturbance is ongoing, punishments are lifted unconditionally regardless of remorse, and the disturbance ends.\nIf the transgressions were voluntary but the target honestly believed they were for the greater good, the GM determines whether the repentance is accepted. If accepted, a penance/quest is assigned; punishments are lifted when it is completed.","link":""},"cause critical wounds":{"name":"Cause Critical Wounds","level":"5","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"8 segments","save":"None","save_type":"","description":"The touched target takes 3d8+3 magical damage, even if it can only be hit by magical weapons. Requires a successful to-hit roll; no saving throw allowed.\nDetails:\nIf you miss the to-hit roll, no damage is inflicted and the spell is lost. Affects normally living creatures only; no effect on golems, constructs, elementals, or undead.","notes":"The touched target takes 3d8+3 magical damage, even if it can only be hit by magical weapons. Requires a successful to-hit roll; no saving throw allowed.\nDetails:\nIf you miss the to-hit roll, no damage is inflicted and the spell is lost. Affects normally living creatures only; no effect on golems, constructs, elementals, or undead.","link":""},"commune":{"name":"Commune","level":"5","school":"Divine divination","range":"Self","duration":"3 rounds","aoe":"You","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"You pray for enlightenment; an invisible divine power answers your questions.\nDetails:\nGods/spirits that are pestered too often may choose not to respond.\nThe divine emissary knows what the gods/spirits you petition know. It is not omniscient, but its knowledge of the Prime Material Plane is likely excellent. It never lies.\nYou may ask one question per cleric level. Each must be asked promptly and respectfully or the emissary departs, ending the spell without further effect. Each answer is:\n“O [adjective] mortal, the answer to your question is…” followed by “yes”, “no”, “I don’t know”, or “it’s complicated”. The emissary may add an adjective before “mortal” (commonly “puny” or “insignificant”, but possibly “annoying”, “stupid”, etc. if patience wears thin).\nOnly you can hear the responses.","notes":"You pray for enlightenment; an invisible divine power answers your questions.\nDetails:\nGods/spirits that are pestered too often may choose not to respond.\nThe divine emissary knows what the gods/spirits you petition know. It is not omniscient, but its knowledge of the Prime Material Plane is likely excellent. It never lies.\nYou may ask one question per cleric level. Each must be asked promptly and respectfully or the emissary departs, ending the spell without further effect. Each answer is:\n“O [adjective] mortal, the answer to your question is…” followed by “yes”, “no”, “I don’t know”, or “it’s complicated”. The emissary may add an adjective before “mortal” (commonly “puny” or “insignificant”, but possibly “annoying”, “stupid”, etc. if patience wears thin).\nOnly you can hear the responses.","link":""},"cure critical wounds":{"name":"Cure Critical Wounds","level":"5","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"8 segments","save":"None","save_type":"","description":"The target regains 3d8+3 hp, up to its normal maximum. Healing beyond maximum is wasted.\nDetails:\nDoes not cure disease, reattach limbs, raise the dead, or heal afflictions not measured in hit points. Generally affects only normally living creatures; no effect on golems, constructs, elementals, or undead.\nReversible as Cause Critical Wounds:","notes":"The target regains 3d8+3 hp, up to its normal maximum. Healing beyond maximum is wasted.\nDetails:\nDoes not cure disease, reattach limbs, raise the dead, or heal afflictions not measured in hit points. Generally affects only normally living creatures; no effect on golems, constructs, elementals, or undead.\nReversible as Cause Critical Wounds:","link":""},"dispel evil":{"name":"Dispel Evil","level":"5","school":"Divine abjuration","range":"Touch","duration":"1 round per cleric level","aoe":"Creature touched","components":"V, S, M","ct":"8 segments","save":"Yes (lessened effect)","save_type":"","description":"Banishes an evil-aligned extraplanar creature. It disappears with an audible “pop”.\nDetails:\nTarget applies its Wisdom save modifier (if any) to the saving throw.\n    Fail save: banished to its home plane.\n    Pass save: not banished, but for the spell’s duration, whenever it attacks you with melee/missile/touch, you may choose to apply -7 to its attack roll.\nWorks only on evil creatures from other planes (demons, devils, efreets, etc.). The banished creature takes its carried/worn items, but no other creatures go with it even if it is carrying them.\nReversible as Dispel Good:","notes":"Banishes an evil-aligned extraplanar creature. It disappears with an audible “pop”.\nDetails:\nTarget applies its Wisdom save modifier (if any) to the saving throw.\n    Fail save: banished to its home plane.\n    Pass save: not banished, but for the spell’s duration, whenever it attacks you with melee/missile/touch, you may choose to apply -7 to its attack roll.\nWorks only on evil creatures from other planes (demons, devils, efreets, etc.). The banished creature takes its carried/worn items, but no other creatures go with it even if it is carrying them.\nReversible as Dispel Good:","link":""},"dispel good":{"name":"Dispel Good","level":"5","school":"Divine abjuration","range":"Touch","duration":"1 round per cleric level","aoe":"Creature touched","components":"V, S, M","ct":"8 segments","save":"Yes (lessened effect)","save_type":"","description":"Banishes a good-aligned extraplanar creature; it disappears with an audible “pop”.\nDetails:\nTarget applies its Wisdom save modifier (if any) to the saving throw.\n    Fail save: banished to its home plane.\n    Pass save: not banished, but for the spell’s duration, whenever it attacks you with melee/missile/touch, you may choose to apply -7 to its attack roll.\nWorks only on good extraplanar creatures (celestials, genies, etc.). The banished creature takes carried/worn items only.","notes":"Banishes a good-aligned extraplanar creature; it disappears with an audible “pop”.\nDetails:\nTarget applies its Wisdom save modifier (if any) to the saving throw.\n    Fail save: banished to its home plane.\n    Pass save: not banished, but for the spell’s duration, whenever it attacks you with melee/missile/touch, you may choose to apply -7 to its attack roll.\nWorks only on good extraplanar creatures (celestials, genies, etc.). The banished creature takes carried/worn items only.","link":""},"false seeing":{"name":"False Seeing","level":"5","school":"Divine divination","range":"Touch","duration":"1 round per cleric level","aoe":"120 ft radius around the touched creature","components":"V, S, M","ct":"8 segments","save":"Yes (negates effect)","save_type":"","description":"Affects one creature: it suffers wild hallucinations, is blinded for the duration, and must make a morale check each round or flee screaming in a random direction.\nDetails:\nTarget adds its Wisdom save modifier to the saving throw.","notes":"Affects one creature: it suffers wild hallucinations, is blinded for the duration, and must make a morale check each round or flee screaming in a random direction.\nDetails:\nTarget adds its Wisdom save modifier to the saving throw.","link":""},"flame strike":{"name":"Flame Strike","level":"5","school":"Divine evocation","range":"60 ft","duration":"Instantaneous","aoe":"Column, 5 ft radius; 30 ft high","components":"V, S, M","ct":"8 segments","save":"Yes (half damage)","save_type":"","description":"Cast at a visible target point on the ground. A pillar of flame strikes; extremely loud (heard within 300 ft).\nDetails:\nCreatures in the area take 6d8 fire damage. If any fiends or celestials are in the area, they instead take 6d8 magical damage (not fire).\nCreatures may save vs spells/magical effects:\n    Pass: half damage; worn/carried items are undamaged.\n    Fail/decline: full damage; roll item saves vs fire for worn/carried objects.\nGM rolls saves vs fire for unattended objects in the area. In 5 ft squares, can hit up to 4 squares (target an intersection). Afterward, the area is charred/sooty with a lingering scent appropriate to the invoked power (incense, brimstone, etc.).","notes":"Cast at a visible target point on the ground. A pillar of flame strikes; extremely loud (heard within 300 ft).\nDetails:\nCreatures in the area take 6d8 fire damage. If any fiends or celestials are in the area, they instead take 6d8 magical damage (not fire).\nCreatures may save vs spells/magical effects:\n    Pass: half damage; worn/carried items are undamaged.\n    Fail/decline: full damage; roll item saves vs fire for worn/carried objects.\nGM rolls saves vs fire for unattended objects in the area. In 5 ft squares, can hit up to 4 squares (target an intersection). Afterward, the area is charred/sooty with a lingering scent appropriate to the invoked power (incense, brimstone, etc.).","link":""},"insect plague":{"name":"Insect Plague","level":"5","school":"Divine conjuration","range":"360 ft","duration":"10 rounds per cleric level","aoe":"Column, 180 ft radius; 60 ft high","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"Conjures a swarm of biting/stinging insects from a visible target point on the ground.\nDetails:\nIf you are level 18 or lower: mundane insects (wasps, clegs, midges, mosquitoes, biting locusts). Each round, at the start of the round, each creature in the area:\n    Takes 1 point piercing damage; and\n    Level 2 / 2 HD or less: must flee until at least 240 ft from the plague’s edge.\n    Level 4 / 4 HD or less: must check morale; on failure, flee until at least 120 ft from the edge.\nIf you are level 19 or higher: may conjure extraplanar insects. Each round, at the start of the round, each creature in the area:\n    Takes 2 points piercing damage; and\n    Level 4 / 4 HD or less: must flee until at least 240 ft from the edge.\n    Level 7 / 7 HD or less: must check morale; on failure, flee until at least 120 ft from the edge.\nOther details:\n    Fire/smoke holds back insects while it lasts (e.g., wall of fire works; fireball/flame strike only clears briefly).\n    Insects can pass through tiny spaces but not impenetrable barriers (can pass through blade barrier/wall of thorns; not wall of force).\n    Insects will not enter water; fully submerged creatures at start of round take no damage.\n    Creatures immune to mundane weapons are unaffected, regardless of HD.\n    Visibility inside is 30 ft.","notes":"Conjures a swarm of biting/stinging insects from a visible target point on the ground.\nDetails:\nIf you are level 18 or lower: mundane insects (wasps, clegs, midges, mosquitoes, biting locusts). Each round, at the start of the round, each creature in the area:\n    Takes 1 point piercing damage; and\n    Level 2 / 2 HD or less: must flee until at least 240 ft from the plague’s edge.\n    Level 4 / 4 HD or less: must check morale; on failure, flee until at least 120 ft from the edge.\nIf you are level 19 or higher: may conjure extraplanar insects. Each round, at the start of the round, each creature in the area:\n    Takes 2 points piercing damage; and\n    Level 4 / 4 HD or less: must flee until at least 240 ft from the edge.\n    Level 7 / 7 HD or less: must check morale; on failure, flee until at least 120 ft from the edge.\nOther details:\n    Fire/smoke holds back insects while it lasts (e.g., wall of fire works; fireball/flame strike only clears briefly).\n    Insects can pass through tiny spaces but not impenetrable barriers (can pass through blade barrier/wall of thorns; not wall of force).\n    Insects will not enter water; fully submerged creatures at start of round take no damage.\n    Creatures immune to mundane weapons are unaffected, regardless of HD.\n    Visibility inside is 30 ft.","link":""},"plane shift":{"name":"Plane Shift","level":"5","school":"Divine conjuration","range":"Touch","duration":"Instantaneous","aoe":"Creatures touched","components":"V, S, M","ct":"8 segments","save":"Depends on use (see below)","save_type":"","description":"Transports either:\n    One unwilling creature, or\n    Up to 7 willing creatures holding hands in a circle, plus optionally the caster,\n    to an Outer Plane.\nIf the creature is native to an Outer Plane, it returns to its origin plane; otherwise the caster chooses which Outer Plane it is sent to.\nDetails:\nIf you touch an unwilling creature, it may attempt a saving throw vs spells/magical effects, adding its Wisdom save modifier. On success, the spell does not affect it.","notes":"Transports either:\n    One unwilling creature, or\n    Up to 7 willing creatures holding hands in a circle, plus optionally the caster,\n    to an Outer Plane.\nIf the creature is native to an Outer Plane, it returns to its origin plane; otherwise the caster chooses which Outer Plane it is sent to.\nDetails:\nIf you touch an unwilling creature, it may attempt a saving throw vs spells/magical effects, adding its Wisdom save modifier. On success, the spell does not affect it.","link":""},"quest":{"name":"Quest","level":"5","school":"Divine enchantment","range":"60 ft","duration":"Until completed","aoe":"Creature touched","components":"V, S, M","ct":"8 segments","save":"Yes (negates effect)","save_type":"","description":"Sets a quest a target creature is compelled to perform. Target must be human, demi-human, or humanoid.\nDetails:\nTarget may save vs spells/other effects, adding Wisdom save modifier. On success, spell ends without effect.\nQuest limitations:\n    Cannot be one that would change the target’s alignment if completed.\n    Must be within the target’s power.\n    Must be possible to complete within a year and a day.\nEnding conditions:\n    You can end it at any time.\n    Any cleric higher level than you can end it by touching the target and willing it to end.\n    Ends when the target returns with proof of completion (or, if it doesn’t know where you are, to the casting location), or when the target dies, or when completion becomes impossible (target of assassination dies; object to retrieve is destroyed; etc.).\nPenalty for procrastination:\nFor each 24 hours the target avoids the quest, it takes a cumulative -1 to all saving throws (periods need not be continuous). Normal daily maintenance is allowed as long as it is acting in good faith toward the quest.","notes":"Sets a quest a target creature is compelled to perform. Target must be human, demi-human, or humanoid.\nDetails:\nTarget may save vs spells/other effects, adding Wisdom save modifier. On success, spell ends without effect.\nQuest limitations:\n    Cannot be one that would change the target’s alignment if completed.\n    Must be within the target’s power.\n    Must be possible to complete within a year and a day.\nEnding conditions:\n    You can end it at any time.\n    Any cleric higher level than you can end it by touching the target and willing it to end.\n    Ends when the target returns with proof of completion (or, if it doesn’t know where you are, to the casting location), or when the target dies, or when completion becomes impossible (target of assassination dies; object to retrieve is destroyed; etc.).\nPenalty for procrastination:\nFor each 24 hours the target avoids the quest, it takes a cumulative -1 to all saving throws (periods need not be continuous). Normal daily maintenance is allowed as long as it is acting in good faith toward the quest.","link":""},"raise dead":{"name":"Raise Dead","level":"5","school":"Divine necromancy","range":"30 ft","duration":"Instantaneous","aoe":"One corpse or undead creature","components":"V, S, M","ct":"10 rounds","save":"Depends on use (see below)","save_type":"","description":"Returns a recently killed person to life, or can be used to kill some undead with physical bodies (works on zombies, not ghosts).\nDetails:\n    Can only raise if death occurred within 1 day per cleric level. (You can still use it to kill an undead that died longer ago.)\n    Body must be sufficiently intact (missing head/heart causes failure).\n    The slain creature must pass a Resurrection Success roll based on Constitution (table 1.1.4a). Failure means no return.\n    Returned creature remembers dying but not the time spent dead.\n    Unless the GM rules otherwise: works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs.\n    Returned creature has 1 hp, is weak/sick, and cannot fight/cast/work until bed rest of 1 full day per day dead.\n    Missing body parts remain missing.\nIf the target is an undead creature (with a physical body):\nIt saves vs spells/other magical effects.\n    Pass: takes 2d8+1 corrosion damage; no other effect.\n    Fail: returned to life if it died recently enough; otherwise it crumbles to dust.\n    A lich, or a vampire older than a century, automatically passes this saving throw.\nReversible as Slay Living:","notes":"Returns a recently killed person to life, or can be used to kill some undead with physical bodies (works on zombies, not ghosts).\nDetails:\n    Can only raise if death occurred within 1 day per cleric level. (You can still use it to kill an undead that died longer ago.)\n    Body must be sufficiently intact (missing head/heart causes failure).\n    The slain creature must pass a Resurrection Success roll based on Constitution (table 1.1.4a). Failure means no return.\n    Returned creature remembers dying but not the time spent dead.\n    Unless the GM rules otherwise: works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs.\n    Returned creature has 1 hp, is weak/sick, and cannot fight/cast/work until bed rest of 1 full day per day dead.\n    Missing body parts remain missing.\nIf the target is an undead creature (with a physical body):\nIt saves vs spells/other magical effects.\n    Pass: takes 2d8+1 corrosion damage; no other effect.\n    Fail: returned to life if it died recently enough; otherwise it crumbles to dust.\n    A lich, or a vampire older than a century, automatically passes this saving throw.\nReversible as Slay Living:","link":""},"slay living":{"name":"Slay Living","level":"5","school":"Divine necromancy","range":"30 ft","duration":"Instantaneous","aoe":"One creature","components":"V, S, M","ct":"1 round","save":"Yes (negates effect)","save_type":"","description":"You speak an Abominable Word and point at a creature. Target may save vs spells/magical effects.\n    Pass: takes 2d8+1 corrosion damage; no other effect.\n    Fail: dies instantly.\nDetails:\nIn some campaigns, Abominable Words are lost secrets obtainable only through ancient lore, extraplanar consultation, or certain liches. Unless the GM rules otherwise, works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs.","notes":"You speak an Abominable Word and point at a creature. Target may save vs spells/magical effects.\n    Pass: takes 2d8+1 corrosion damage; no other effect.\n    Fail: dies instantly.\nDetails:\nIn some campaigns, Abominable Words are lost secrets obtainable only through ancient lore, extraplanar consultation, or certain liches. Unless the GM rules otherwise, works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs.","link":""},"true seeing":{"name":"True Seeing","level":"5","school":"Divine divination","range":"Touch","duration":"1 round per cleric level","aoe":"120 ft radius around the touched creature","components":"V, S, M","ct":"8 segments","save":"None","save_type":"","description":"Target sees things as they truly are within the area: detects illusions/displacements (and may choose to see through them), perceives astral/ethereal beings, hidden/secret things, sees alignment auras, recognizes polymorph/shapechange (and may choose to see true or altered form), and sees through darkness/bright light/fog/mist.\nDetails:\nGods and god-like beings, artifacts, and relics may produce effects immune to this spell.\nReversible as False Seeing:","notes":"Target sees things as they truly are within the area: detects illusions/displacements (and may choose to see through them), perceives astral/ethereal beings, hidden/secret things, sees alignment auras, recognizes polymorph/shapechange (and may choose to see true or altered form), and sees through darkness/bright light/fog/mist.\nDetails:\nGods and god-like beings, artifacts, and relics may produce effects immune to this spell.\nReversible as False Seeing:","link":""},"aerial servant":{"name":"Aerial Servant","level":"6","school":"Divine conjuration","range":"10 ft","duration":"1 day per cleric level","aoe":"Nil","components":"V, S, M","ct":"9 segments","save":"None","save_type":"","description":"Summons an aerial servant (invisible elemental being) and binds it to your service. Unless you or it travels to another plane, it magically knows the direction and distance to both the summoning location and your current location.\nDetails:\n    Spell fails unless you are on the Prime Material, Elemental Plane of Air, Ethereal, or Astral plane.\n    It cannot speak and knows no languages, but understands your spoken commands via the spell.\n    It hates being controlled; the spell compels strict obedience.\n    It does not have to obey:\n        commands that are obviously self-destructive, or\n        commands to attack a creature.\n    The servant is dismissed (spell ends) when: it is killed; you are killed; you dismiss it; you leave the plane of casting; or it leaves that plane.\n    Not evil, but it cannot cross Protection from Evil or a magic circle, and must recoil from a holy symbol held out by a cleric or paladin.\n    Nothing prevents it from attacking you; best practice is to stand protected until commands are complete.\n    If its mission can’t be completed, the spell ends; it is no longer commanded and will usually return and attack you.","notes":"Summons an aerial servant (invisible elemental being) and binds it to your service. Unless you or it travels to another plane, it magically knows the direction and distance to both the summoning location and your current location.\nDetails:\n    Spell fails unless you are on the Prime Material, Elemental Plane of Air, Ethereal, or Astral plane.\n    It cannot speak and knows no languages, but understands your spoken commands via the spell.\n    It hates being controlled; the spell compels strict obedience.\n    It does not have to obey:\n        commands that are obviously self-destructive, or\n        commands to attack a creature.\n    The servant is dismissed (spell ends) when: it is killed; you are killed; you dismiss it; you leave the plane of casting; or it leaves that plane.\n    Not evil, but it cannot cross Protection from Evil or a magic circle, and must recoil from a holy symbol held out by a cleric or paladin.\n    Nothing prevents it from attacking you; best practice is to stand protected until commands are complete.\n    If its mission can’t be completed, the spell ends; it is no longer commanded and will usually return and attack you.","link":""},"animate object":{"name":"Animate Object","level":"6","school":"Divine transmutation","range":"30 ft","duration":"1 round per cleric level","aoe":"One object up to 1 cubic foot per cleric level","components":"V, S","ct":"9 segments","save":"None","save_type":"","description":"Infuses a spirit into an inanimate object, which becomes a temporary creature that obeys you. When the spell ends, it becomes inanimate again; damage it took remains.\nDetails:\n    No self-preservation; obeys all commands even if self-destructive.\n    Statblock is “animated object” in the OSRIC GM Guide.\n    If the object is too large, spell ends without effect and the slot is still used.\n    Cannot speak/knows no languages; understands your spoken commands via the spell.\n    Spell ends if the animated object is killed; you are killed; you dismiss it; or you leave the plane of casting.\n    Commanding it does not take your combat action, but in any round you give it a command you can’t cast spells with a verbal component.","notes":"Infuses a spirit into an inanimate object, which becomes a temporary creature that obeys you. When the spell ends, it becomes inanimate again; damage it took remains.\nDetails:\n    No self-preservation; obeys all commands even if self-destructive.\n    Statblock is “animated object” in the OSRIC GM Guide.\n    If the object is too large, spell ends without effect and the slot is still used.\n    Cannot speak/knows no languages; understands your spoken commands via the spell.\n    Spell ends if the animated object is killed; you are killed; you dismiss it; or you leave the plane of casting.\n    Commanding it does not take your combat action, but in any round you give it a command you can’t cast spells with a verbal component.","link":""},"blade barrier":{"name":"Blade Barrier","level":"6","school":"Divine evocation","range":"30 ft","duration":"3 rounds per cleric level","aoe":"Sphere of radius 5/10/15/20 ft around a visible target point","components":"V, S","ct":"9 segments","save":"None","save_type":"","description":"Creates a stationary sphere of whirling blades around the target point; radius chosen at casting and cannot be changed.\nDetails:\n    Blades cannot penetrate rock or brick; they do not appear in those portions of the area.\n    Ends if you are killed or you dismiss it.\n    Blades are not magical; creatures only hittable by magical weapons take no damage.\n    Contact damage: 8d8 slashing, no attack roll, no save. Triggered when:\n        a creature enters or reaches through from either side,\n        the barrier appears on a creature,\n        a creature remains in it (damage at start of each round).\n    Barrier is narrow; standing adjacent is safe, but melee attacks through it cause damage.\n    Physical missiles/projectiles through it: -3 to attack roll. Magical/energy attacks do not take this penalty.","notes":"Creates a stationary sphere of whirling blades around the target point; radius chosen at casting and cannot be changed.\nDetails:\n    Blades cannot penetrate rock or brick; they do not appear in those portions of the area.\n    Ends if you are killed or you dismiss it.\n    Blades are not magical; creatures only hittable by magical weapons take no damage.\n    Contact damage: 8d8 slashing, no attack roll, no save. Triggered when:\n        a creature enters or reaches through from either side,\n        the barrier appears on a creature,\n        a creature remains in it (damage at start of each round).\n    Barrier is narrow; standing adjacent is safe, but melee attacks through it cause damage.\n    Physical missiles/projectiles through it: -3 to attack roll. Magical/energy attacks do not take this penalty.","link":""},"conjure animals":{"name":"Conjure Animals","level":"6","school":"Divine conjuration","range":"30 ft","duration":"2 rounds per cleric level","aoe":"Up to 1 creature per cleric level (varies by strength chosen)","components":"V, S","ct":"9 segments","save":"None","save_type":"","description":"Conjures animal allies at a visible target point. You choose desired strength (Weak/Medium/Strong/Mighty); stronger types yield fewer animals. GM rolls/chooses what appears.\nWeak — 1 per cleric level\n1–3 Baboon; 4–9 Dog; 10–16 Giant rat; 17–20 Jackal\nMedium — 1 per 2 cleric levels (round down)\n1–4 Badger; 5–14 Herd animal; 15–20 Horse\nStrong — 1 per 3 cleric levels (round down)\n1–2 Boar; 3–5 Camel; 6–7 Giant goat; 8–9 Horse; 10–11 Hyena; 12–13 Leopard; 14–15 Phorusrhacid (Axe Beak); 16–17 Stag; 18–20 Wolf\nMighty — 1 per 4 cleric levels (round down)\n1–3 Ape; 4–5 Bear; 6–7 Boar; 8–9 Bull; 10–12 Dire wolf; 13–14 Leopard; 15–16 Lion; 17–18 Sabretooth tiger; 19–20 Tiger\nDetails:\n    Spell fails unless on the Prime Material Plane.\n    Animals understand your spoken commands; need not obey self-destructive commands.\n    Ends when all are killed; you are killed; you dismiss them; you leave the plane of casting; or they leave that plane.\n    No XP for defeating them.\n    VTT spacing: GM may place; typical approach is one per unoccupied square in/adjacent to the target point. If no space, an animal appears later when space opens; duration extends accordingly for late arrivals.","notes":"Conjures animal allies at a visible target point. You choose desired strength (Weak/Medium/Strong/Mighty); stronger types yield fewer animals. GM rolls/chooses what appears.\nWeak — 1 per cleric level\n1–3 Baboon; 4–9 Dog; 10–16 Giant rat; 17–20 Jackal\nMedium — 1 per 2 cleric levels (round down)\n1–4 Badger; 5–14 Herd animal; 15–20 Horse\nStrong — 1 per 3 cleric levels (round down)\n1–2 Boar; 3–5 Camel; 6–7 Giant goat; 8–9 Horse; 10–11 Hyena; 12–13 Leopard; 14–15 Phorusrhacid (Axe Beak); 16–17 Stag; 18–20 Wolf\nMighty — 1 per 4 cleric levels (round down)\n1–3 Ape; 4–5 Bear; 6–7 Boar; 8–9 Bull; 10–12 Dire wolf; 13–14 Leopard; 15–16 Lion; 17–18 Sabretooth tiger; 19–20 Tiger\nDetails:\n    Spell fails unless on the Prime Material Plane.\n    Animals understand your spoken commands; need not obey self-destructive commands.\n    Ends when all are killed; you are killed; you dismiss them; you leave the plane of casting; or they leave that plane.\n    No XP for defeating them.\n    VTT spacing: GM may place; typical approach is one per unoccupied square in/adjacent to the target point. If no space, an animal appears later when space opens; duration extends accordingly for late arrivals.","link":""},"find the path":{"name":"Find the Path","level":"6","school":"Divine divination","range":"Touch","duration":"1 turn per cleric level","aoe":"One creature","components":"V, S, M","ct":"3 rounds","save":"None","save_type":"","description":"Touched creature magically knows the route to one specific destination you choose. If multiple routes exist, only the shortest is known. If none exists, you learn that and the spell ends.\nDetails:\nKnows the route, not precise distances/directions; cannot draw an accurate map. Learns nothing about hazards on the route.\nReversible as Hide the Path:","notes":"Touched creature magically knows the route to one specific destination you choose. If multiple routes exist, only the shortest is known. If none exists, you learn that and the spell ends.\nDetails:\nKnows the route, not precise distances/directions; cannot draw an accurate map. Learns nothing about hazards on the route.\nReversible as Hide the Path:","link":""},"harm":{"name":"Harm","level":"6","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"One creature","components":"V, S","ct":"1 round","save":"Yes (negates)","save_type":"","description":"You speak an Abominable Word and attempt to touch the target. If it fails a save vs spells, it takes enough magical damage to reduce its hit points to 1d4.\nDetails:\nIn some campaigns, Abominable Words are lost secrets. Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","notes":"You speak an Abominable Word and attempt to touch the target. If it fails a save vs spells, it takes enough magical damage to reduce its hit points to 1d4.\nDetails:\nIn some campaigns, Abominable Words are lost secrets. Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","link":""},"heal":{"name":"Heal","level":"6","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"1 round","save":"None","save_type":"","description":"Target regains almost all lost hit points: up to normal total minus 1d4. Cures blindness, deafness, diseases, madnesses, and poisons completely. Ends feeblemind.\nDetails:\nDoes not raise the dead and does not remove lycanthropy. Affects normally living creatures only; no effect on golems, constructs, elementals, undead.\nReversible as Harm:","notes":"Target regains almost all lost hit points: up to normal total minus 1d4. Cures blindness, deafness, diseases, madnesses, and poisons completely. Ends feeblemind.\nDetails:\nDoes not raise the dead and does not remove lycanthropy. Affects normally living creatures only; no effect on golems, constructs, elementals, undead.\nReversible as Harm:","link":""},"hide the path":{"name":"Hide the Path","level":"6","school":"Divine enchantment","range":"Touch","duration":"1 turn per cleric level","aoe":"One creature","components":"V, S, M","ct":"3 rounds","save":"Yes (negates)","save_type":"","description":"Touched creature loses sense of direction; if it tries to move, its heading is randomly determined.\nDetails:\nIt can still attack and cast spells normally; only directional movement becomes random.","notes":"Touched creature loses sense of direction; if it tries to move, its heading is randomly determined.\nDetails:\nIt can still attack and cast spells normally; only directional movement becomes random.","link":""},"speak with monsters":{"name":"Speak with Monsters","level":"6","school":"Divine divination","range":"Caster","duration":"1 turn","aoe":"30 ft radius around you","components":"V, S, M","ct":"9 segments","save":"None","save_type":"","description":"Universal translator for any creature or plant intelligent enough to communicate. Translates their “speech” into a language you understand and translates your spoken words for them within the area.\nDetails:\n    Intelligence < animal (1) cannot communicate meaningfully even with this spell.\n    Does not make hostile creatures friendly.\n    Translation is per-language; different species may not understand each other without repetition, though you can understand all of them.","notes":"Universal translator for any creature or plant intelligent enough to communicate. Translates their “speech” into a language you understand and translates your spoken words for them within the area.\nDetails:\n    Intelligence < animal (1) cannot communicate meaningfully even with this spell.\n    Does not make hostile creatures friendly.\n    Translation is per-language; different species may not understand each other without repetition, though you can understand all of them.","link":""},"stone tell":{"name":"Stone Tell","level":"6","school":"Divine divination","range":"Touch","duration":"1 turn","aoe":"Up to 10 cubic feet","components":"V, S, M","ct":"10 rounds","save":"None","save_type":"","description":"Gives stone the ability to hear your questions and mentally reply with brief, truthful answers to the best of its knowledge.\nDetails:\nOnly you hear replies. Stone only knows what occurred within 20 ft of it (making area of effect relevant).","notes":"Gives stone the ability to hear your questions and mentally reply with brief, truthful answers to the best of its knowledge.\nDetails:\nOnly you hear replies. Stone only knows what occurred within 20 ft of it (making area of effect relevant).","link":""},"word of recall":{"name":"Word of Recall","level":"6","school":"Divine transmutation","range":"Caster","duration":"Instantaneous","aoe":"You plus creatures/objects up to 25 lb per cleric level","components":"V","ct":"Fast","save":"None","save_type":"","description":"Teleports you (and possibly others) to a prepared sanctuary. Before using, you must designate a sanctuary by standing there and praying privately for 10 minutes.\nDetails:\n    Only one sanctuary at a time; designating a new one replaces the old.\n    Transports willing creatures only; unwilling creatures are unaffected.\n    Worn/held/carried gear is transported. Weight limit cannot be exploited to bring additional “creatures” unless very small (≈ 30 lb or less).","notes":"Teleports you (and possibly others) to a prepared sanctuary. Before using, you must designate a sanctuary by standing there and praying privately for 10 minutes.\nDetails:\n    Only one sanctuary at a time; designating a new one replaces the old.\n    Transports willing creatures only; unwilling creatures are unaffected.\n    Worn/held/carried gear is transported. Weight limit cannot be exploited to bring additional “creatures” unless very small (≈ 30 lb or less).","link":""},"earthquake":{"name":"Earthquake","level":"7","school":"Divine transmutation","range":"360 ft","duration":"1 round","aoe":"Contiguous stone area up to 5 ft diameter per cleric level","components":"V, S, M","ct":"10 rounds","save":"None (see below)","save_type":"","description":"Creates a minor earthquake; cracks open with a chance to swallow creatures.\nDetails:\n    Non-material creatures and creatures flying/levitating do not fall in.\n    GM may rule extremely large creatures are too large to fall in.\n    Elementals survive the fall and can return after 3d6 rounds.\n    Chance to fall (no saving throw):\n        Small: 1 in 4\n        Medium: 1 in 6\n        Large: 1 in 8\n    Creatures swallowed take 12d10 blunt damage.","notes":"Creates a minor earthquake; cracks open with a chance to swallow creatures.\nDetails:\n    Non-material creatures and creatures flying/levitating do not fall in.\n    GM may rule extremely large creatures are too large to fall in.\n    Elementals survive the fall and can return after 3d6 rounds.\n    Chance to fall (no saving throw):\n        Small: 1 in 4\n        Medium: 1 in 6\n        Large: 1 in 8\n    Creatures swallowed take 12d10 blunt damage.","link":""},"energy drain":{"name":"Energy Drain","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"3 rounds","save":"None","save_type":"","description":"Drains one experience level from the target.\nDetails:\n    Touch required (may require a to-hit roll). No saving throw.\n    Target loses one life energy level; if level 1 or lower (or 1 HD or less), it is killed.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","notes":"Drains one experience level from the target.\nDetails:\n    Touch required (may require a to-hit roll). No saving throw.\n    Target loses one life energy level; if level 1 or lower (or 1 HD or less), it is killed.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","link":""},"holy word":{"name":"Holy Word","level":"7","school":"Divine conjuration","range":"Nil","duration":"Varies","aoe":"30 ft radius","components":"V","ct":"Fast","save":"None (see below)","save_type":"","description":"Utter a holy word; all non-good-aligned creatures in the area suffer severe effects.\nDetails:\n    All fiends and evil-aligned elementals are instantly banished to their home plane.\n    Other non-good creatures suffer based on level/HD:\n        < 4: Killed (instant)\n        4–7: Paralyzed for 10d4 rounds\n        8–11: Move halved; -4 to attacks for 2d4 rounds\n            11: Move -10 ft; -2 to attacks for 1d4 rounds\n    Deities/similar power unaffected.\n    Does not work in the Lower Outer Planes.\n    Alignment interpretation is GM-facing: some tables apply it to any non-good; others only to evil.\nReversible as Unholy Word.","notes":"Utter a holy word; all non-good-aligned creatures in the area suffer severe effects.\nDetails:\n    All fiends and evil-aligned elementals are instantly banished to their home plane.\n    Other non-good creatures suffer based on level/HD:\n        < 4: Killed (instant)\n        4–7: Paralyzed for 10d4 rounds\n        8–11: Move halved; -4 to attacks for 2d4 rounds\n            11: Move -10 ft; -2 to attacks for 1d4 rounds\n    Deities/similar power unaffected.\n    Does not work in the Lower Outer Planes.\n    Alignment interpretation is GM-facing: some tables apply it to any non-good; others only to evil.\nReversible as Unholy Word.","link":""},"regenerate":{"name":"Regenerate","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S, M","ct":"3 rounds","save":"None","save_type":"","description":"Regrows or reattaches a lost body part; also heals organ damage or injuries not addressed by Heal/Cure spells (e.g., can restore sight to damaged eyes).\nDetails:\n    Target must be alive. Cannot restore head or brain; if missing, spell fails.\n    If severed part is present: instantly reattached.\n    If missing/destroyed: regrows over 2d4 combat rounds.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.\nReversible as Wither.","notes":"Regrows or reattaches a lost body part; also heals organ damage or injuries not addressed by Heal/Cure spells (e.g., can restore sight to damaged eyes).\nDetails:\n    Target must be alive. Cannot restore head or brain; if missing, spell fails.\n    If severed part is present: instantly reattached.\n    If missing/destroyed: regrows over 2d4 combat rounds.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.\nReversible as Wither.","link":""},"restoration":{"name":"Restoration","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"One creature","components":"V, S","ct":"3 rounds","save":"None","save_type":"","description":"Restores one lost level from undead level drain (or similar). Also has broader restorative effects at GM discretion.\nDetails:\n    Must be cast within one day per your cleric level of the level loss; outside that window it cannot restore.\n    Target gains enough XP to be at the start of the restored level.\n    Ends feeblemind or similar mind-damaging effects.\nReversible as Energy Drain.","notes":"Restores one lost level from undead level drain (or similar). Also has broader restorative effects at GM discretion.\nDetails:\n    Must be cast within one day per your cleric level of the level loss; outside that window it cannot restore.\n    Target gains enough XP to be at the start of the restored level.\n    Ends feeblemind or similar mind-damaging effects.\nReversible as Energy Drain.","link":""},"resurrection":{"name":"Resurrection","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"The piece of flesh or bone you choose","components":"V, S, M","ct":"10 rounds","save":"Only when used vs undead","save_type":"","description":"Returns the dead to life by returning a soul to a portion of its body and regrowing the rest if needed. Target remembers dying but not the interval while dead.\nDetails:\n    If successful: returns with full hit points; retains prepared spells/unused slots it had at death.\n    Missing parts are restored.\n    Default ancestry limitation (unless GM says otherwise): works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs (souls vs spirits rationale).\n    Death must be within 10 years per your cleric level (but can still be used against older-dead undead).\n    Requires at least 1 ounce of flesh/bone (not fingernail/hair).\n    Target must be deceased (cannot clone from a living body part).\n    Target must pass a Resurrection Success roll (by CON). Failure makes the target forever dead to further resurrection/raise dead.\nAgainst undead:\n    Undead saves vs spells/magical effects.\n        Pass: takes 5d8+5 corrosion damage; no other effect. (Lich or vampire > century gets +4 on this save.)\n        Fail: returned to life if within time limit; otherwise crumbles to dust.\nReversible as Surcease.","notes":"Returns the dead to life by returning a soul to a portion of its body and regrowing the rest if needed. Target remembers dying but not the interval while dead.\nDetails:\n    If successful: returns with full hit points; retains prepared spells/unused slots it had at death.\n    Missing parts are restored.\n    Default ancestry limitation (unless GM says otherwise): works on humans, half-elves, gnomes, dwarfs, halflings; not elves or half-orcs (souls vs spirits rationale).\n    Death must be within 10 years per your cleric level (but can still be used against older-dead undead).\n    Requires at least 1 ounce of flesh/bone (not fingernail/hair).\n    Target must be deceased (cannot clone from a living body part).\n    Target must pass a Resurrection Success roll (by CON). Failure makes the target forever dead to further resurrection/raise dead.\nAgainst undead:\n    Undead saves vs spells/magical effects.\n        Pass: takes 5d8+5 corrosion damage; no other effect. (Lich or vampire > century gets +4 on this save.)\n        Fail: returned to life if within time limit; otherwise crumbles to dust.\nReversible as Surcease.","link":""},"surcease":{"name":"Surcease","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"One creature","components":"V, S, M","ct":"10 rounds","save":"Yes (lessened effect)","save_type":"","description":"Kills the target on a failed save; damages on a successful save. Involves an Abominable Word that prevents future raising/resurrection of the body (except by a deity/similar power).\nDetails:\n    Abominable Words may be lost secrets in some campaigns.\n    Default ancestry limitation (unless GM says otherwise): humans, half-elves, gnomes, dwarfs, halflings; not elves/half-orcs.\n    Requires touch (may require to-hit roll). Target may save vs spells/magical effects:\n        Pass: takes 5d8+5 corrosion damage.\n        Fail: dies instantly and cannot be raised/resurrected except by deity-level intervention.","notes":"Kills the target on a failed save; damages on a successful save. Involves an Abominable Word that prevents future raising/resurrection of the body (except by a deity/similar power).\nDetails:\n    Abominable Words may be lost secrets in some campaigns.\n    Default ancestry limitation (unless GM says otherwise): humans, half-elves, gnomes, dwarfs, halflings; not elves/half-orcs.\n    Requires touch (may require to-hit roll). Target may save vs spells/magical effects:\n        Pass: takes 5d8+5 corrosion damage.\n        Fail: dies instantly and cannot be raised/resurrected except by deity-level intervention.","link":""},"unholy word":{"name":"Unholy Word","level":"7","school":"Divine conjuration","range":"Nil","duration":"Varies","aoe":"30 ft radius","components":"V","ct":"Fast","save":"None (see below)","save_type":"","description":"Utter an unholy word; all non-evil-aligned creatures in the area suffer severe effects.\nDetails:\n    All celestials and good-aligned elementals are instantly banished to their home plane.\n    Other non-evil creatures suffer based on level/HD (same table structure as Holy Word):\n        < 4: Killed (instant)\n        4–7: Paralyzed for 10d4 rounds\n        8–11: Move halved; -4 to attacks for 2d4 rounds\n            11: Move -10 ft; -2 to attacks for 1d4 rounds\n    Deities/similar power unaffected.\n    Does not work in the Upper Outer Planes.","notes":"Utter an unholy word; all non-evil-aligned creatures in the area suffer severe effects.\nDetails:\n    All celestials and good-aligned elementals are instantly banished to their home plane.\n    Other non-evil creatures suffer based on level/HD (same table structure as Holy Word):\n        < 4: Killed (instant)\n        4–7: Paralyzed for 10d4 rounds\n        8–11: Move halved; -4 to attacks for 2d4 rounds\n            11: Move -10 ft; -2 to attacks for 1d4 rounds\n    Deities/similar power unaffected.\n    Does not work in the Upper Outer Planes.","link":""},"wind walk":{"name":"Wind Walk","level":"7","school":"Divine transmutation","range":"Caster","duration":"1 hour per cleric level","aoe":"Creatures of your choice within 20 ft radius of you","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"Turns you and designated creatures into magical vapor (cloud/steam). In this form you can fly and pass through any gap wider than ½ inch.\nDetails:\n    Must affect you. Also includes up to 1 human-sized creature per 8 cleric levels.\n    Only willing creatures affected; any affected creature may end the spell on itself at any time.\n    Movement: 60 ft per round.\n    If the spell ends while flying: creature falls immediately.\n    If the spell ends while in a narrow space: takes 6d6 blunt damage, then appears prone in the nearest unoccupied space.","notes":"Turns you and designated creatures into magical vapor (cloud/steam). In this form you can fly and pass through any gap wider than ½ inch.\nDetails:\n    Must affect you. Also includes up to 1 human-sized creature per 8 cleric levels.\n    Only willing creatures affected; any affected creature may end the spell on itself at any time.\n    Movement: 60 ft per round.\n    If the spell ends while flying: creature falls immediately.\n    If the spell ends while in a narrow space: takes 6d6 blunt damage, then appears prone in the nearest unoccupied space.","link":""},"wither":{"name":"Wither","level":"7","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S, M","ct":"3 rounds","save":"None (but see below)","save_type":"","description":"Degenerates living tissue (opposite of Regenerate).\nDetails:\n    On a successful touch, target may save vs spells; on success takes half damage.\n    Damage: 8d12+32 corrosion, or 4d12+16 on a successful save.\n    If you touched a limb and it failed its save, the limb withers.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","notes":"Degenerates living tissue (opposite of Regenerate).\nDetails:\n    On a successful touch, target may save vs spells; on success takes half damage.\n    Damage: 8d12+32 corrosion, or 4d12+16 on a successful save.\n    If you touched a limb and it failed its save, the limb withers.\n    Affects normally living creatures only; no effect on golems, constructs, elementals, undead.","link":""},"bless":{"name":"Bless","level":"1","school":"Divine transmutation","range":"60 ft","duration":"6 rounds","aoe":"Cube, 50 ft × 50 ft × 50 ft","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"The selected creatures in the area of effect may choose to gain +1 to “to hit” rolls in combat and +5% to morale checks.","notes":"The selected creatures in the area of effect may choose to gain +1 to “to hit” rolls in combat and +5% to morale checks.\n\nDetails:\n\nThis spell can target creatures within the area of effect that aren’t in melee when the spell is cast (they must be 10 ft distant from enemies).\n\nWhen you cast the spell, you can choose any number of creatures and decide they aren’t affected.\n\nThis spell is normally used as a blessing on your allies (and yourself), granting bonuses in combat and morale checks.\n\nAlternatively, you may bless an object or a place, even if you memorised the spell for blessing creatures. This usually has no direct game-mechanical effect, but can influence events outside the ordinary rules.","link":""},"ceremony":{"name":"Ceremony","level":"1","school":"Invocation","range":"Touch","duration":"Permanent","aoe":"One creature, one item, or area (see below)","components":"V, S, M","ct":"1 hour","save":"Special","save_type":"","description":"Ceremony has a number of applications within the religious organization, depending upon the level of the cleric. The effect of a ceremony spell does not leave behind an aura of magic, although in some cases an aura of good or evil might be present and thus detectable. The specific ceremony spells can vary from religion to religion, but usually encompass these: 1st-level cleric: coming of age, burial, marriage. 3rd-level cleric: dedication, investiture, consecrate item. 5th-level cleric: ordination, special vows. 7th-level cleric: consecrate ground. 9th-level cleric: anathematize. Each variety requires a cleric of the indicated level or higher. For all ceremony spells except anathematize, no saving throw is called for, since the recipient is either inanimate or presumed willing. Any version except anathematize simply fails if cast upon a person unwilling to receive the benefit. Coming of Age grants a +1 bonus to one saving throw to a young person. Burial protects a corpse for one week as if by protection from evil; anyone disinterring it during that time must save versus spell or flee in fear for 1 turn. Marriage has no tangible after-effect, but usually carries moral or legal significance. Dedication admits the recipient into the caster’s religion and is permanent unless superseded by a higher-level dedication. Investiture must be performed on any aspiring cleric before 1st level. Consecrate Item must be performed on objects placed on altars or within religious edifices. Ordination must be performed before a cleric can become priest of a congregation or gain followers; the officiating cleric must be higher level. Special Vows may be received by a would-be cavalier or paladin; while in effect they grant immunity to bestow curse and impose a -4 penalty on saves against quest from a cleric of the same alignment. Consecrate Ground must be performed before holy or unholy structures are built, or for graveyards it grants automatic turning effects as a 3rd-level cleric. Anathematize brands an offender with a holy or unholy sign; unwilling subjects save versus spell at -4, and the brand fades only after proper atonement. The material component always involves the cleric’s holy symbol.","notes":"Coming of age, burial, marriage, dedication, investiture, consecrate item, ordination, special vows, consecrate ground, and anathematize are all covered by this spell depending on cleric level. Material component always involves the cleric’s holy symbol.","link":""},"combine":{"name":"Combine","level":"1","school":"Evocation","range":"Touch","duration":"Special","aoe":"The circle of clerics","components":"V, S","ct":"1 round","save":"None","save_type":"","description":"This spell enables three to five clerics to combine their abilities and thereby empower one of their number to cast a spell or turn undead with greater efficacy. The highest-level cleric of the group, or one of such if more than one qualifies, stands at the center while the others join hands in a surrounding circle. All participating clerics then cast the combine spell together. The central cleric temporarily functions as if of higher level, gaining one level for each encircling cleric. The maximum gain is four levels, and the maximum duration is 3 turns. This increase applies to the cleric’s effective level for determining results of attempts to turn undead and for spell details that vary by caster level. The encircling clerics must concentrate on maintaining the combine effect. They gain no armor class bonuses from shield or dexterity, and attackers gain a +4 bonus on attack rolls against them. The central cleric gains no additional spells, but may cast any previously memorized spell or spells, often with improved effects.","notes":"Three to five clerics combine power; the central cleric gains one effective level per supporting cleric, up to +4 levels, for up to 3 turns.","link":""},"command":{"name":"Command","level":"1","school":"Divine enchantment","range":"10 ft","duration":"1 round","aoe":"One creature","components":"V","ct":"Fast","save":"See below","save_type":"","description":"You issue a one-word command to the target creature, and it may be forced to obey for one round.","notes":"You issue a one-word command to the target creature, and it may be forced to obey for one round. The command must be very clear (unambiguous), so only a few commands are normally used.\n\nDetails:\n\nThe creature must be able to hear you, and it doesn’t have to obey unless the command is in a language it understands.\n\nThis spell is considered a charm and a form of mental domination, so many creatures—such as golems, constructs, elementals, and undead—are immune.\n\nThe target creature doesn’t have to obey unless the command is a verb.","link":""},"create water":{"name":"Create Water","level":"1","school":"Divine conjuration","range":"10 ft","duration":"Instantaneous","aoe":"See below","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"For each level you have in the cleric class, you conjure up to sixteen litres of water from the Elemental Plane of Water at a targeted point.","notes":"For each level you have in the cleric class, you conjure up to sixteen litres of water from the Elemental Plane of Water at a targeted point. You may limit the amount created.\n\nDetails:\n\nUnless the target point is inside a receptacle, the water immediately spills.\n\nThe target point can’t be inside a creature.","link":""},"cure light wounds":{"name":"Cure Light Wounds","level":"1","school":"Divine necromancy","range":"Touch","duration":"Instantaneous","aoe":"Creature touched","components":"V, S","ct":"5 segments","save":"None","save_type":"","description":"The target regains 1d8 hit points, up to its normal maximum.","notes":"The target regains 1d8 hit points, up to its normal maximum. Healing beyond the target’s normal maximum is wasted. You must be able to see and touch the target.\n\nDetails:\n\nThis spell can’t cure disease, reattach limbs, raise the dead, or heal afflictions not measured in hit points.\n\nIn general, the spell affects only normally living creatures. It has no effect on golems, constructs, elementals, or undead.","link":""},"endure cold/heat":{"name":"Endure Cold/Heat","level":"1","school":"Alteration","range":"Touch","duration":"9 turns/level","aoe":"One creature","components":"V, S","ct":"1 round","save":"None","save_type":"","description":"The recipient of this spell is protected from normal extremes of cold or heat, depending upon which application is used. He or she can stand unclothed in temperatures as low as -30°F or as high as 130°F without ill effect. A temperature extreme beyond those limits causes 1 hit point of exposure damage per hour for every degree above or below the limit. Without such protection, exposure damage is 1 hit point per turn for each degree of temperature. The spell lasts for the stated duration, or until the recipient is affected by any form of magical cold or magical heat. The recipient does not suffer damage from the magical heat or cold during the round in which the spell is broken, but is vulnerable to all such attacks beginning on the following round. The spell is also cancelled instantly if either resist fire or resist cold is cast upon the recipient.","notes":"Reversible. Protects from normal heat or cold, but ends when magical heat or cold affects the subject.","link":""},"invisibility to undead":{"name":"Invisibility to Undead","level":"1","school":"Illusion/Phantasm","range":"Touch","duration":"6 rounds","aoe":"One individual","components":"V, S, M","ct":"4 segments","save":"Neg.","save_type":"","description":"This spell is similar to sanctuary, but affects only undead of 4 or fewer hit dice. A saving throw versus spell is made for each type of undead within 30 feet of the caster. If the saving throw fails, all undead of that type ignore the caster completely for the duration of the spell. This also negates subsequent attempts by the caster to turn those undead. If the saving throw succeeds, however, all undead of that type attack the caster in preference to any other possible targets. The effect ends if the caster attacks or attempts to cast any other spell. If the caster is of neutral morals with respect to good and evil, the undead save at -2.","notes":"Material component: the cleric’s holy symbol. Affects undead of 4 HD or fewer only.","link":""},"magic stone":{"name":"Magic Stone","level":"1","school":"Alteration","range":"2\"","duration":"6 rounds or until used","aoe":"One small stone or pebble","components":"V, S","ct":"1 round","save":"None","save_type":"","description":"The cleric places a magical aura upon a small stone or pebble. The stone can be thrown at a target up to 4\" distant, acts as a +1 weapon to hit, and if a hit is scored it inflicts 1 point of damage. If the stone travels more than 4\" or does not hit, it loses its dweomer and falls harmlessly to the ground. A magic stone must be thrown within 6 rounds after the spell is completed or it reverts to an ordinary stone. A hit from the stone breaks the concentration of a spell caster only if the victim fails a saving throw versus spell. Any target with innate magic resistance cannot be affected by the stone. A shield spell, brooch of shielding, protection from normal missiles, minor globe of invulnerability, or similar stronger magic protects against a magic stone. Clerics of higher levels can enchant additional stones. Some religions may forbid this spell because it permits the use of a missile weapon of sorts.","notes":"Creates one or more +1 stones that inflict 1 point of damage on a hit and may disrupt casting.","link":""},"penetrate disguise":{"name":"Penetrate Disguise","level":"1","school":"Divination","range":"12\"","duration":"1 round","aoe":"One individual","components":"V, S","ct":"2 rounds","save":"Neg.","save_type":"","description":"By means of this spell, the cleric is empowered to see through a disguise composed solely of makeup or altered clothing, that is, one non-magical in nature. The cleric cannot identify the actual class or profession of the disguised figure, nor the figure’s true appearance. The spell merely reveals that the target is posing as someone or something else. The spell does not detect actual rank or status and cannot reveal an illusion for what it is, though it can detect whether a figure is the object of a friends spell. It cannot detect any deception involving alignment. The target is allowed a saving throw versus spell. If this saving throw succeeds, the disguise is actually enhanced in the eyes of the cleric, and the caster becomes convinced that the target truly is what he claims to be. Being under the effects of a bless spell, wearing magic armor, or using a magic protective item such as a cloak or ring grants the target an appropriate bonus to the saving throw.","notes":"Detects only non-magical disguises made with makeup or clothing. A successful save actually enhances the disguise in the caster’s eyes.","link":""},"portent":{"name":"Portent","level":"1","school":"Divination","range":"Touch","duration":"Special","aoe":"Spell caster or figure touched","components":"V, S, M","ct":"1 turn","save":"None","save_type":"","description":"This spell enables the cleric to tell something of his or another figure’s future luck. The luck takes the form of an improvement or reduction in a to hit roll or saving throw at some unknown point in the future for the subject of the spell. After the spell is cast, the Dungeon Master secretly rolls 1d12 to determine when in the future the portent takes effect and 1d6 to determine the exact effect: 1 = -3, 2 = -2, 3 = -1, 4 = +1, 5 = +2, 6 = +3. The DM should indicate only whether the portent is good, fair, or poor. The 1d12 result indicates how many meaningful attack rolls or saving throws occur before the portent applies. When the designated roll occurs, the result is adjusted upward or downward as indicated. The material component is a numbered wheel or tea leaves.","notes":"The DM secretly determines when the portent applies and whether it is favorable or unfavorable.","link":""},"precipitation":{"name":"Precipitation","level":"1","school":"Alteration","range":"1\"/level","duration":"1 segment/level","aoe":"3\" diameter cylinder up to 12\" high","components":"V, S, M","ct":"3 segments","save":"None","save_type":"","description":"When this spell is cast, all water vapor in the atmosphere within the area of effect is precipitated in the form of light rain. The rain continues for as many segments as the caster has levels. Thin, light material becomes damp in 1 segment and thoroughly wet thereafter. Twigs and heavy material such as canvas become damp in 2 segments and wet thereafter. Flat, relatively non-porous surfaces become damp in 1 segment and filmed with water thereafter. Semi-porous surfaces become damp on the surface in 2 segments and thoroughly wet after 5 segments. Porous materials absorb the rain. Small flames such as candles are extinguished by 1 segment of precipitation. Small fires slow and become smoky for 1 round after precipitation ceases. Large fires are not materially affected. If the temperature is above 90°F, duration is doubled except in arid regions. Where the temperature ranges from 33° to 31°F, the precipitation falls as sleet; at 30°F and below, it falls as snow. If magical heat is applied, a cloud of warm fog of double the area is formed; if magical cold is applied, normal ice forms. Material component: a pinch of silver dust.","notes":"Creates light rain with environmental effects such as dampness, extinguishing small flames, sleet or snow in cold temperatures, and fog or ice when magical heat or cold is applied.","link":""},"purify food & drink":{"name":"Purify Food & Drink","level":"1","school":"Divine transmutation","range":"30 ft","duration":"Instantaneous","aoe":"1 cubic foot per cleric level","components":"V, S","ct":"1 round","save":"None","save_type":"","description":"You detoxify a volume of food and drink, removing spoilage, disease, and poisons.","notes":"You detoxify a volume of food and drink, removing spoilage, disease, and poisons. This spell also neutralises unholy water.\n\nDetails:\n\nThis spell affects objects, not creatures.\n\nIt makes substances safe for you.","link":""},"remove fear":{"name":"Remove Fear","level":"1","school":"Divine abjuration","range":"Touch","duration":"1 turn, or instantaneous (see below)","aoe":"Creature touched","components":"V, S","ct":"4 segments","save":"None","save_type":"","description":"This spell bolsters courage against existing or future fear effects.","notes":"This spell bolsters courage: it either grants new saving throws versus existing fear effects or provides a bonus to future saving throws against fear.\n\nDetails:\n\nIf the target is already affected by fear, the spell is instantaneous and grants one new saving throw.\n\nIf the target is not already affected by fear, duration is 1 turn and the target gains +4 on each saving throw against fear.","link":""},"resist cold":{"name":"Resist Cold","level":"1","school":"Divine abjuration","range":"Touch","duration":"1 turn per cleric level","aoe":"Creature touched","components":"V, S, M","ct":"1 round","save":"None","save_type":"","description":"This spell protects you or one creature from cold.","notes":"This spell protects you or one creature from cold, including special protections against magical cold in combat.\n\nDetails:\n\nThe warded creature is safe from non-magical cold.\n\nAll cold damage is halved. If already halved, halve it again.","link":""},"sanctuary":{"name":"Sanctuary","level":"1","school":"Divine abjuration","range":"Touch","duration":"2 rounds + 1 round per cleric level","aoe":"Creature touched","components":"V, S, M","ct":"4 segments","save":"See below","save_type":"","description":"You ward yourself or one other creature so that enemies perceive the protected creature as a low-priority target.","notes":"You ward yourself or one other creature so that enemies perceive the protected creature as a low-priority target.\n\nFor the duration, any creature attempting an attack or targeted spell against the protected creature must first attempt a saving throw vs spells.\n\nDetails:\n\nIf the protected creature makes a weapon attack or uses a spell that affects an enemy, the spell ends.","link":""}};

const spellNorm = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
const spellFind = (value) => {
  const key = spellNorm(value);
  if (SPELL_MASTER_ITEMS[key]) return SPELL_MASTER_ITEMS[key];
  try {
    if (CLERIC_SPELL_MASTER && CLERIC_SPELL_MASTER[key]) return CLERIC_SPELL_MASTER[key];
  } catch (err) {}
  return null;
};

function dedupeSpellText(spell) {
  const desc = String(spell.description || '').trim();
  const notes = String(spell.notes || '').trim();
  if (!desc && !notes) return '';
  if (!desc) return notes;
  if (!notes) return desc;
  const nd = desc.replace(/\s+/g, ' ').trim().toLowerCase();
  const nn = notes.replace(/\s+/g, ' ').trim().toLowerCase();
  if (nd === nn) return desc;
  if (nn.startsWith(nd)) return notes;
  if (nd.startsWith(nn)) return desc;
  return desc;
}

function fillSpellGroupRow(sectionName, rowId, spell, fixedLevel, silentFlag) {
  const full = dedupeSpellText(spell);
  const output = {};
  output[`repeating_${sectionName}_${rowId}_spell_name`] = spell.name || '';
  output[`repeating_${sectionName}_${rowId}_spell_level`] = String(fixedLevel);
  output[`repeating_${sectionName}_${rowId}_spell_level_display`] = String(fixedLevel);
  output[`repeating_${sectionName}_${rowId}_spell_school`] = spell.school || '';
  output[`repeating_${sectionName}_${rowId}_spell_range`] = spell.range || '';
  output[`repeating_${sectionName}_${rowId}_spell_duration`] = spell.duration || '';
  output[`repeating_${sectionName}_${rowId}_spell_aoe`] = spell.aoe || '';
  output[`repeating_${sectionName}_${rowId}_spell_components`] = spell.components || '';
  output[`repeating_${sectionName}_${rowId}_spell_ct`] = spell.ct || '';
  output[`repeating_${sectionName}_${rowId}_spell_save`] = spell.save || '';
  output[`repeating_${sectionName}_${rowId}_spell_save_type`] = spell.save_type || '';
  output[`repeating_${sectionName}_${rowId}_spell_description`] = full;
  output[`repeating_${sectionName}_${rowId}_spell_notes`] = spell.notes || '';
  output[`repeating_${sectionName}_${rowId}_spell_link`] = spell.link || '';
  output[`repeating_${sectionName}_${rowId}_spell_name_select`] = spell.name || '';
  output[`repeating_${sectionName}_${rowId}_spell_name_select_cleric`] = spell.name || '';
  output[`repeating_${sectionName}_${rowId}_spell_caster_class_name`] = spell.class || '';
  output[`repeating_${sectionName}_${rowId}_spell_caster_class_level`] = spell.level || String(fixedLevel);
  setAttrs(output, {silent: !!silentFlag});
}

function refreshSpellDims(sectionName) {
  getSectionIDs(`repeating_${sectionName}`, function(ids) {
    const fields = ['spell_memorized_only'];
    ids.forEach(function(id) {
      fields.push(`repeating_${sectionName}_${id}_spell_memorized`);
    });
    getAttrs(fields, function(values) {
      const memOnly = String(values['spell_memorized_only'] || '0') === '1';
      const output = {};
      ids.forEach(function(id) {
        const n = parseInt(values[`repeating_${sectionName}_${id}_spell_memorized`] || '0', 10) || 0;
        output[`repeating_${sectionName}_${id}_spell_dim`] = (memOnly && n <= 0) ? '1' : '0';
      });
      setAttrs(output, {silent:true});
    });
  });
}

on('change:repeating_spelllvl0:spell_name_select', function(eventInfo) {
  const rowId = eventInfo.sourceAttribute.split('_')[2];
  const spell = spellFind(eventInfo.newValue || '');
  if (spell) fillSpellGroupRow('spelllvl0', rowId, spell, 0, false);
});

on('change:repeating_spelllvl0:spell_name', function(eventInfo) {
  if (eventInfo.sourceType === 'sheetworker') return;
  const rowId = eventInfo.sourceAttribute.split('_')[2];
  const spell = spellFind(eventInfo.newValue || '');
  if (spell) fillSpellGroupRow('spelllvl0', rowId, spell, 0, false);
});

on('change:repeating_spelllvl0:spell_memorized change:spell_memorized_only', function() {
  refreshSpellDims('spelllvl0');
});

on('sheet:opened', function() {
  getSectionIDs('repeating_spelllvl0', function(ids) {
    if (!ids.length) {
      refreshSpellDims('spelllvl0');
      return;
    }
    const fields = [];
    ids.forEach(function(id) {
      fields.push(`repeating_spelllvl0_${id}_spell_name`);
      fields.push(`repeating_spelllvl0_${id}_spell_name_select`);
      fields.push(`repeating_spelllvl0_${id}_spell_name_select_cleric`);
    });
    getAttrs(fields, function(values) {
      ids.forEach(function(id) {
        const selected = values[`repeating_spelllvl0_${id}_spell_name_select`] || values[`repeating_spelllvl0_${id}_spell_name_select_cleric`] || '';
        const named = values[`repeating_spelllvl0_${id}_spell_name`] || '';
        const spell = spellFind(selected) || spellFind(named);
        if (spell) fillSpellGroupRow('spelllvl0', id, spell, 0, true);
      });
      refreshSpellDims('spelllvl0');
    });
  });
});

