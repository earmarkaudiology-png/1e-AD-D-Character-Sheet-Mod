  function normEquipLabel(v) {
    return String(v || '')
      .toLowerCase()
      .replace(/’/g, "'")
      .replace(/&/g, ' and ')
      .replace(/[()]/g, ' ')
      .replace(/[^a-z0-9]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function explicitLookup(label) {
    return EXPLICIT_NONMAGICAL_LOOKUP[normEquipLabel(label)] || null;
  }

  function writeExplicitWeightCost(rowId, label) {
    const hit = explicitLookup(label);
    if (!hit) return;
    const out = {};
    out[`repeating_equipment_${rowId}_equipment_weight`] = String(hit.weight ?? 0);
    out[`repeating_equipment_${rowId}_equipment_cost`] = String(hit.cost ?? 0);
    setAttrs(out, {silent:false});
  }

  function scheduleExplicitWeightCost(rowId, label) {
    if (!label) return;
    [0, 50, 150, 400, 900, 1800, 3200].forEach(function(ms) {
      setTimeout(function() {
        writeExplicitWeightCost(rowId, label);
      }, ms);
    });
  }

  function resolveAndSchedule(rowId) {
    const f1 = `repeating_equipment_${rowId}_equipment_item_select_all`;
    const f2 = `repeating_equipment_${rowId}_equipment_item`;
    const f3 = `repeating_equipment_${rowId}_equipment_weight`;
    const f4 = `repeating_equipment_${rowId}_equipment_cost`;
    getAttrs([f1, f2, f3, f4], function(v) {
      const label = v[f1] || v[f2] || '';
      if (!label) return;
      const hit = explicitLookup(label);
      if (!hit) return;
      const currentWeight = String(v[f3] || '0').trim();
      const currentCost = String(v[f4] || '0').trim();
      const desiredWeight = String(hit.weight ?? 0);
      const desiredCost = String(hit.cost ?? 0);
      if (currentWeight !== desiredWeight || currentCost !== desiredCost) {
        scheduleExplicitWeightCost(rowId, label);
      }
    });
  }

  function sweepAllExplicitWeightCost() {
    getSectionIDs('repeating_equipment', function(ids) {
      if (!ids || !ids.length) return;
      ids.forEach(function(id) {
        resolveAndSchedule(id);
      });
    });
  }

  on('change:repeating_equipment:equipment_item_select_all change:repeating_equipment:equipment_item change:repeating_equipment:equipment_type change:repeating_equipment:equipment_show_type', function(e) {
    const rowId = e.sourceAttribute.split('_')[2];
    resolveAndSchedule(rowId);
  });

  on('change:repeating_equipment:equipment_weight change:repeating_equipment:equipment_cost', function(e) {
    if (e.sourceType === 'sheetworker') return;
    const rowId = e.sourceAttribute.split('_')[2];
    resolveAndSchedule(rowId);
  });

  on('sheet:opened', function() {
    sweepAllExplicitWeightCost();
    setTimeout(sweepAllExplicitWeightCost, 300);
    setTimeout(sweepAllExplicitWeightCost, 1000);
    setTimeout(sweepAllExplicitWeightCost, 2500);
