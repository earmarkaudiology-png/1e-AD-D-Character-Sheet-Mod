  });

  // Equipment row weight/cost sync.
  on('change:repeating_equipment:equipment_item_select_all change:repeating_equipment:equipment_item', function (e) {
    var rowId = e.sourceAttribute.split('_')[2];
    scheduleEquipmentSync(rowId);
  });

  // Rebuild totals whenever relevant equipment/weapon/load fields change.
  on(
    'sheet:opened ' +
    'change:repeating_equipment:equipment_weight ' +
    'change:repeating_equipment:equipment_cost ' +
    'change:repeating_equipment:equipment_quantity ' +
    'change:repeating_equipment:equipment_carried_select ' +
    'change:repeating_equipment:equipment_carried ' +
    'change:repeating_weapon:weapon_weight ' +
    'change:repeating_weapon:weapon_cost ' +
    'change:repeating_weapon:weapon_quantity ' +
    'change:armor_weight change:armortype2_weight change:armorshield_weight change:armorhelmet_weight ' +
    'change:armor_cost change:armortype2_cost change:armorshield_cost change:armorhelmet_cost ' +
    'change:pp change:gp change:ep change:sp change:cp ' +
    'change:toggle_lbs ' +
    'change:normal_load_adjusted change:heavy_load change:very_heavy_load change:max_load ' +
    'remove:repeating_equipment remove:repeating_weapon',
    function () {
      setTimeout(recomputeAllTotals, 20);
