          var wt = firstNumber(v['repeating_weapon_' + id + '_weapon_weight'] || 0);
          var cost = num(v['repeating_weapon_' + id + '_weapon_cost'] || 0);
          totalWeight += (wt * qty);
          totalCost += (cost * qty);
