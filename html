  }
  function updateDisplayWeightsFinal(){
    getAttrs([
      'toggle_lbs',
      'total_equipment_weight','total_weapon_weight','total_armor_weight','total_coin_weight','total_weight'
    ], function(v){
      var useLbs = String(v.toggle_lbs || '0') === '1';
      function show(x){ return useLbs ? (n(x) / 10) : n(x); }
      setAttrs({
        total_equipment_weight_display: fmt(show(v.total_equipment_weight)),
        total_weapon_weight_display: fmt(show(v.total_weapon_weight)),
        total_armor_weight_display: fmt(show(v.total_armor_weight)),
        total_coin_weight_display: fmt(show(v.total_coin_weight)),
        total_weight_display: fmt(show(v.total_weight))
      }, {silent:false});
    });
  }

  on('sheet:opened change:toggle_lbs change:total_equipment_weight change:total_weapon_weight change:total_armor_weight change:total_coin_weight change:total_weight', function(){
    updateDisplayWeightsFinal();
    setTimeout(updateDisplayWeightsFinal, 50);
    setTimeout(updateDisplayWeightsFinal, 200);
  });
})();
</script>
