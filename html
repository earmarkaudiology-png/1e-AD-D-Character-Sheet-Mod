  });

  on('change:armorshield change:armorshield_select_all', function () {
    clearArmorWhenBlank('armorshield', 'armorshield_select_all', 'armorshield_weight', 'armorshield_cost', {
      armorshield_ac: '0',
      armorshield_base: '0',
      armorshield_bulk: '0'
    });
    setTimeout(recomputeAllTotals, 30);
  });

  on('change:armorhelmet change:armorhelmet_select_all', function () {
    clearArmorWhenBlank('armorhelmet', 'armorhelmet_select_all', 'armorhelmet_weight', 'armorhelmet_cost', {
      armorhelmet_ac: '10',
      armorhelmet_bulk: '0'
    });
