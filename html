          out.total_armor_weight = String(Math.round(other.armorWeight * 100) / 100);
          out.total_armor_weight_display = formatDisplayWeight(other.armorWeight, other.useLbs);
          out.total_armor_cost = String(Math.round(other.armorCost * 100) / 100);

          out.total_coin_weight = String(Math.round(other.coinGp * 100) / 100);
          out.total_coin_weight_display = formatDisplayWeight(other.coinGp, other.useLbs);

          out.total_weight = String(Math.round(totalGp * 100) / 100);
          out.total_weight_display = formatDisplayWeight(totalGp, other.useLbs);
          out.total_cost = String(Math.round(totalCost * 100) / 100);

          out.current_encumbrance = String(enc);
          out.current_encumbrance_label = label;

          setAttrs(out, { silent: false });
        });
      });
    });
  }

  // Hard-disable armor row IDs so armor details stop treating equipment rows as linked children.
  on('sheet:opened change:armortype1_row_id change:armortype2_row_id change:armorshield_row_id change:armorhelmet_row_id', function () {
    setNoArmorLink();
  });

  // Clear stale armor weights when selections are blank.
  on('change:armortype change:armortype_select_all', function () {
    clearArmorWhenBlank('armortype', 'armortype_select_all', 'armor_weight', 'armor_cost', {
      armortype_ac: '10',
      armortype_base: '10',
      armortype_bulk: '0'
    });
    setTimeout(recomputeAllTotals, 30);
  });

  on('change:armortype2 change:armortype2_select_all', function () {
    clearArmorWhenBlank('armortype2', 'armortype2_select_all', 'armortype2_weight', 'armortype2_cost', {
      armortype2_ac: '10',
