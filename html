function syncIntSpellLimitsPHB() {
  getAttrs(['intelligence'], function(values) {
    const score = parseInt(values.intelligence || '0', 10) || 0;
    const out = {};
    if (score >= 19) {
      out.knowspell = '95';
      out.minspells = '10';
      out.maxspells = 'All';
    } else if (score >= 18) {
      out.knowspell = '85';
      out.minspells = '9';
      out.maxspells = '18';
    } else if (score >= 17) {
      out.knowspell = '75';
      out.minspells = '8';
      out.maxspells = '14';
    } else if (score >= 15) {
      out.knowspell = '65';
      out.minspells = '7';
      out.maxspells = '11';
    } else if (score >= 13) {
      out.knowspell = '55';
      out.minspells = '6';
      out.maxspells = '9';
    } else if (score >= 10) {
      out.knowspell = '45';
      out.minspells = '5';
      out.maxspells = '7';
    } else if (score >= 9) {
      out.knowspell = '35';
      out.minspells = '4';
      out.maxspells = '6';
    }
    if (Object.keys(out).length) setAttrs(out, {silent:true});
  });
}

on('change:intelligence', function() { syncIntSpellLimitsPHB(); });
on('sheet:opened', function() { syncIntSpellLimitsPHB(); });


function syncSpellCurrentFromRows(sectionName, levelIndex) {
  getSectionIDs(`repeating_${sectionName}`, function(ids) {
    const out = {};
    if (!ids.length) {
      out[`spells_lvl_${levelIndex}_current`] = '0';
      setAttrs(out, {silent:false});
      return;
    }
    const fields = [];
    ids.forEach(function(id) {
      fields.push(`repeating_${sectionName}_${id}_spell_memorized`);
    });
    getAttrs(fields, function(values) {
      let total = 0;
      ids.forEach(function(id) {
        total += parseInt(values[`repeating_${sectionName}_${id}_spell_memorized`] || '0', 10) || 0;
      });
      out[`spells_lvl_${levelIndex}_current`] = String(Math.max(0, total));
      setAttrs(out, {silent:false});
    });
  });
}

