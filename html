    var fTxt = 'repeating_equipment_' + rowId + '_equipment_item';
    var fWt = 'repeating_equipment_' + rowId + '_equipment_weight';
    var fCost = 'repeating_equipment_' + rowId + '_equipment_cost';
    var fType = 'repeating_equipment_' + rowId + '_equipment_type';
    var fShowType = 'repeating_equipment_' + rowId + '_equipment_show_type';
    var fMagical = 'repeating_equipment_' + rowId + '_equipment_magical';

    getAttrs([fSel, fTxt, fWt, fCost, fType, fShowType, fMagical], function (v) {
      var label = String(v[fSel] || v[fTxt] || '').trim();
      if (!label) return;

      var hit = lookupEquipmentData(label);
      if (!hit) return;

      var out = {};
      if (String(v[fSel] || '') !== hit.label) out[fSel] = hit.label;
      if (String(v[fTxt] || '') !== hit.label) out[fTxt] = hit.label;
      if (String(v[fWt] || '0') !== String(hit.weight)) out[fWt] = String(hit.weight);
      if (String(v[fCost] || '0') !== String(hit.cost)) out[fCost] = String(hit.cost);
      if (String(v[fType] || '0') !== String(hit.type)) out[fType] = String(hit.type);
