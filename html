    rawLevel = values.level || values.caster_class1_level || '0';
  } else if (which === '2') {
    rawName = values.secondclass || '';
    rawLevel = values.level_2 || values.caster_class1_level || '0';
  } else {
    rawName = values.thirdclass || '';
    rawLevel = values.level_3 || values.caster_class1_level || '0';
  }
  const sync = String(values.sync_caster_class1 || '0') === '1';
  if (!sync) {
